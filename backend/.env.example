# Copy this to .env and fill in real values — never commit .env to git

PORT=5000
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@your-cluster.mongodb.net/khata?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_random_64_char_string_before_deploying
JWT_EXPIRE=7d
NODE_ENV=production

# Your Vercel frontend URL — no trailing slash
# For multiple origins, separate with commas:
# CLIENT_URL=https://khatanest.vercel.app,https://khatanest-preview.vercel.app
CLIENT_URL=https://your-app.vercel.app

# Optional — defaults to midnight daily
CRON_SCHEDULE=0 0 * * *