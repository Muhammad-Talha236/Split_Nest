/* KhataNest legacy color system
   Fonts: Plus Jakarta Sans (body/UI), Syne (brand), JetBrains Mono (numbers) */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root,
[data-theme="dark"] {
  --bg: #0A0C10;
  --surface: #111318;
  --surface-alt: #16191F;
  --surface-elevated: #1B2028;
  --border: #1E2229;
  --overlay: rgba(5, 8, 12, 0.76);

  --accent: #2ECC9A;
  --accent-dim: #1A7A5C;
  --accent-soft: rgba(46, 204, 154, 0.12);
  --accent-glow: rgba(46, 204, 154, 0.25);
  --accent-hover: #3BDAA9;
  --accent-active: #24B887;
  --accent-ring: rgba(46, 204, 154, 0.25);
  --accent-strong: #0F5B45;

  --blue: #5B8DEF;
  --blue-soft: rgba(91, 141, 239, 0.12);
  --primary: #5B8DEF;
  --primary-hover: #73A0F2;
  --primary-active: #4476D8;
  --primary-soft: rgba(91, 141, 239, 0.12);
  --primary-ring: rgba(91, 141, 239, 0.28);
  --primary-strong: #8EB0F4;

  --yellow: #FFB547;
  --yellow-soft: rgba(255, 181, 71, 0.12);
  --red: #FF5C6A;
  --red-soft: rgba(255, 92, 106, 0.12);

  --text: #E8EAF0;
  --text-muted: #6B7280;
  --text-dim: #9CA3AF;
  --neutral: #9CA3AF;

  --radius: 12px;
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  --shadow-md: 0 8px 32px rgba(0, 0, 0, 0.5);

  --banner-soft: rgba(46, 204, 154, 0.08);
  --brand-gradient: linear-gradient(135deg, #2ECC9A 0%, #1A7A5C 100%);
  --button-primary-gradient: linear-gradient(135deg, #2ECC9A 0%, #1A7A5C 100%);
  --button-accent-gradient: linear-gradient(135deg, #5B8DEF 0%, #4476D8 100%);
  --button-primary-text: #000000;
  --button-accent-text: #FFFFFF;

  --avatar-1: #2ECC9A;
  --avatar-2: #5B8DEF;
  --avatar-3: #FFB547;
  --avatar-4: #E879F9;
  --avatar-5: #FB923C;
  --avatar-6: #34D399;

  --status-positive: #2ECC9A;
  --status-positive-soft: rgba(46, 204, 154, 0.12);
  --status-attention: #FFB547;
  --status-attention-soft: rgba(255, 181, 71, 0.12);
}

[data-theme="light"] {
  --bg: #EEF3F8;
  --surface: #FFFFFF;
  --surface-alt: #F5F8FC;
  --surface-elevated: #FCFDFF;
  --border: #D5DFEA;
  --overlay: rgba(15, 23, 42, 0.24);

  --accent: #0F9F84;
  --accent-dim: #0C7463;
  --accent-soft: rgba(15, 159, 132, 0.13);
  --accent-glow: rgba(15, 159, 132, 0.24);
  --accent-hover: #13B293;
  --accent-active: #09594B;
  --accent-ring: rgba(15, 159, 132, 0.22);
  --accent-strong: #09594B;

  --blue: #2F76DE;
  --blue-soft: rgba(47, 118, 222, 0.12);
  --primary: #2F76DE;
  --primary-hover: #4988E4;
  --primary-active: #215FBE;
  --primary-soft: rgba(47, 118, 222, 0.12);
  --primary-ring: rgba(47, 118, 222, 0.22);
  --primary-strong: #1E53A5;

  --yellow: #C76A07;
  --yellow-soft: rgba(199, 106, 7, 0.12);
  --red: #DC4A58;
  --red-soft: rgba(220, 74, 88, 0.12);

  --text: #152235;
  --text-muted: #64748B;
  --text-dim: #3F5067;
  --neutral: #64748B;

  --radius: 12px;
  --shadow: 0 10px 30px rgba(20, 40, 80, 0.08);
  --shadow-md: 0 18px 48px rgba(20, 40, 80, 0.12);

  --banner-soft: rgba(15, 159, 132, 0.09);
  --brand-gradient: linear-gradient(135deg, #0F9F84 0%, #0B6B58 100%);
  --button-primary-gradient: linear-gradient(135deg, #12A88A 0%, #0A705D 100%);
  --button-accent-gradient: linear-gradient(135deg, #3B84E8 0%, #245FC1 100%);
  --button-primary-text: #F7FFFC;
  --button-accent-text: #FFFFFF;

  --avatar-1: #0F9F84;
  --avatar-2: #2F76DE;
  --avatar-3: #C76A07;
  --avatar-4: #B833C7;
  --avatar-5: #E66718;
  --avatar-6: #0D9488;

  --status-positive: #0F9F84;
  --status-positive-soft: rgba(15, 159, 132, 0.12);
  --status-attention: #C76A07;
  --status-attention-soft: rgba(199, 106, 7, 0.12);
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 15px;
  font-weight: 400;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-feature-settings: 'kern' 1, 'liga' 1;
  transition: background 0.3s ease, color 0.3s ease;
}

*[style*="DM Sans"],
div[style*="DM Sans"],
span[style*="DM Sans"],
p[style*="DM Sans"],
button[style*="DM Sans"] {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
}

*[style*="Syne"],
h1[style*="Syne"],
h2[style*="Syne"],
div[style*="Syne"],
h1,
h2,
h3 {
  font-family: 'Syne', 'Plus Jakarta Sans', sans-serif !important;
}

*[style*="monospace"],
code,
kbd,
pre,
samp {
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace !important;
  font-feature-settings: 'tnum' 1;
  font-variant-numeric: tabular-nums;
}

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: var(--surface);
}

::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 999px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--neutral);
}

input,
select,
textarea {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: var(--surface);
  color: var(--text);
  font-size: 14px;
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.3s;
}

input:focus,
select:focus,
textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft);
}

input::placeholder,
textarea::placeholder {
  color: var(--text-muted);
}

[data-theme="light"] input,
[data-theme="light"] select,
[data-theme="light"] textarea {
  background: #F8FAFC;
  border-color: #CBD5E0;
}

[data-theme="light"] input:focus,
[data-theme="light"] select:focus,
[data-theme="light"] textarea:focus {
  background: #FFFFFF;
  border-color: var(--accent);
}

button {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  cursor: pointer;
  font-weight: 700;
  letter-spacing: 0.3px;
}

[data-theme="light"] tr:hover td {
  background: #F0F7F4 !important;
}

[data-theme="light"] .card,
[data-theme="light"] [style*="border: 1px solid var(--border)"] {
  box-shadow: var(--shadow);
}

.page-enter {
  animation: pageIn 0.25s ease;
}

.theme-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--surface-alt);
  color: var(--text);
  box-shadow: var(--shadow);
}

.theme-toggle__swatch {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  background: var(--brand-gradient);
  box-shadow: 0 0 0 3px var(--accent-soft);
  flex-shrink: 0;
}

.card-surface {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  box-shadow: var(--shadow);
}

@keyframes pageIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@media (max-width: 768px) {
  .hide-mobile {
    display: none !important;
  }

  .full-mobile {
    width: 100% !important;
  }
}

*, *::before, *::after {
  transition: background-color 0.25s ease, border-color 0.25s ease, color 0.1s ease;
}

input,
select,
textarea,
button {
  transition: border-color 0.2s, box-shadow 0.2s, background-color 0.2s, color 0.1s;
}

.members-page {
  display: grid;
  gap: 22px;
}

.members-hero {
  position: relative;
  overflow: hidden;
  padding: 28px;
  border-radius: 28px;
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--border));
  background:
    linear-gradient(145deg, color-mix(in srgb, var(--surface-alt) 92%, transparent), color-mix(in srgb, var(--surface) 96%, transparent)),
    radial-gradient(circle at top left, var(--accent-soft), transparent 48%);
  box-shadow: var(--shadow-md);
}

.members-hero__bg {
  position: absolute;
  border-radius: 999px;
  filter: blur(6px);
  pointer-events: none;
}

.members-hero__bg--left {
  width: 240px;
  height: 240px;
  top: -120px;
  left: -90px;
  background: color-mix(in srgb, var(--accent) 16%, transparent);
}

.members-hero__bg--right {
  width: 220px;
  height: 220px;
  right: -80px;
  bottom: -120px;
  background: color-mix(in srgb, var(--blue) 14%, transparent);
}

.members-hero__content {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-start;
  flex-wrap: wrap;
}

.members-hero__copy {
  max-width: 700px;
}

.members-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.members-hero__title {
  margin: 0;
  font-size: clamp(30px, 5vw, 44px);
  font-weight: 900;
  letter-spacing: -1.4px;
  color: var(--text);
}

.members-hero__subtitle {
  max-width: 620px;
  margin-top: 10px;
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.7;
}

.members-hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.members-chip {
  display: inline-flex;
  align-items: center;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, transparent);
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 700;
}

.members-chip--accent {
  border-color: var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
}

.members-hero__actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.members-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0 18px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.2px;
  cursor: pointer;
  transform: translateY(0) scale(1);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease, background-color 0.24s ease, color 0.24s ease;
}

.members-btn:hover {
  transform: translateY(-2px) scale(1.01);
}

.members-btn--primary {
  background: var(--button-primary-gradient);
  color: var(--button-primary-text);
  box-shadow: 0 14px 28px color-mix(in srgb, var(--accent) 18%, transparent);
}

.members-btn--primary:hover {
  box-shadow: 0 18px 36px color-mix(in srgb, var(--accent) 24%, transparent);
}

.members-btn--secondary {
  background: color-mix(in srgb, var(--surface) 94%, transparent);
  color: var(--text);
  border-color: var(--border);
  box-shadow: 0 10px 22px color-mix(in srgb, var(--bg) 18%, transparent);
}

.members-btn--secondary:hover {
  border-color: color-mix(in srgb, var(--blue) 25%, var(--border));
  box-shadow: 0 14px 26px color-mix(in srgb, var(--blue) 14%, transparent);
}

.members-btn--danger {
  background: linear-gradient(135deg, color-mix(in srgb, var(--red) 16%, transparent), color-mix(in srgb, var(--red) 6%, transparent));
  color: var(--red);
  border-color: rgba(255, 92, 106, 0.28);
  box-shadow: 0 10px 22px color-mix(in srgb, var(--red) 12%, transparent);
}

.members-btn--danger:hover {
  box-shadow: 0 16px 30px color-mix(in srgb, var(--red) 18%, transparent);
}

.members-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 14px;
}

.members-stat {
  padding: 20px 18px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow);
}

.members-stat--positive {
  border-color: var(--accent-glow);
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 96%, transparent));
}

.members-stat--danger {
  border-color: rgba(255, 92, 106, 0.25);
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 96%, transparent));
}

.members-stat--warning {
  border-color: color-mix(in srgb, var(--yellow) 25%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--yellow) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 96%, transparent));
}

.members-stat--info {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 96%, transparent));
}

.members-stat__label {
  margin-bottom: 10px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.members-stat__value {
  color: var(--text);
  font-size: 28px;
  font-weight: 900;
  letter-spacing: -1px;
}

.members-stat__hint {
  margin-top: 8px;
  color: var(--text-dim);
  font-size: 12px;
}

.members-directory {
  padding: 22px;
  border-radius: 28px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow);
}

.members-directory__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 14px;
  margin-bottom: 18px;
  flex-wrap: wrap;
}

.members-section-title {
  margin: 0;
  color: var(--text);
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.8px;
}

.members-section-copy {
  margin-top: 6px;
  color: var(--text-dim);
  font-size: 13px;
  line-height: 1.6;
}

.members-directory__hint {
  padding: 8px 12px;
  border-radius: 999px;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 800;
}

.members-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}

.member-card {
  position: relative;
  overflow: hidden;
  min-height: 250px;
  padding: 22px;
  border-radius: 26px;
  border: 1px solid color-mix(in srgb, var(--member-accent) 22%, var(--border));
  background:
    radial-gradient(circle at top right, color-mix(in srgb, var(--member-accent) 14%, transparent), transparent 34%),
    linear-gradient(165deg, var(--member-accent-soft), transparent 46%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: 0 16px 40px color-mix(in srgb, var(--bg) 22%, transparent);
  transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
}

.member-card::before {
  content: "";
  position: absolute;
  inset: 1px;
  border-radius: 22px;
  background: linear-gradient(180deg, color-mix(in srgb, var(--member-accent-wash) 90%, transparent), transparent 40%);
  pointer-events: none;
}

.member-card:hover,
.member-card:focus-within {
  transform: translateY(-6px) scale(1.01);
  border-color: color-mix(in srgb, var(--member-accent) 42%, var(--border));
  box-shadow: 0 28px 56px color-mix(in srgb, var(--member-accent) 20%, transparent);
}

.member-card--with-actions {
  padding-bottom: 86px;
}

.member-card__top,
.member-card__balance,
.member-card__meta,
.member-card__actions {
  position: relative;
  z-index: 1;
}

.member-card__top {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14px;
  margin-bottom: 20px;
  min-height: 88px;
}

.member-card__identity {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: start;
  gap: 14px;
  min-width: 0;
}

.member-card__identity-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
  min-width: 0;
  min-height: 58px;
}

.member-card__name {
  margin: 0;
  color: var(--text);
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -0.6px;
  line-height: 1.12;
  min-width: 0;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.member-card__email {
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.45;
  min-width: 0;
  min-height: 18px;
  max-height: 18px;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  word-break: normal;
  overflow-wrap: normal;
  opacity: 0.92;
}

.member-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
  white-space: nowrap;
  backdrop-filter: blur(10px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
}

.member-card__tag-rail {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  align-content: flex-start;
  gap: 8px;
  min-width: 0;
  max-width: 112px;
}

.member-tag--admin {
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 16%, transparent), color-mix(in srgb, var(--surface) 88%, transparent));
  color: var(--accent);
  border: 1px solid var(--accent-glow);
}

.member-tag--member {
  background: linear-gradient(135deg, color-mix(in srgb, var(--blue) 14%, transparent), color-mix(in srgb, var(--surface) 88%, transparent));
  color: var(--blue);
  border: 1px solid color-mix(in srgb, var(--blue) 24%, transparent);
}

.member-tag--self {
  background: linear-gradient(135deg, color-mix(in srgb, var(--yellow) 14%, transparent), color-mix(in srgb, var(--surface) 88%, transparent));
  color: var(--yellow);
  border: 1px solid color-mix(in srgb, var(--yellow) 32%, transparent);
}

.member-card__balance {
  margin-bottom: 16px;
  padding: 18px 18px 16px;
  border-radius: 20px;
  border: 1px solid color-mix(in srgb, var(--member-accent) 18%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    linear-gradient(135deg, color-mix(in srgb, var(--member-accent) 6%, transparent), transparent 60%);
  backdrop-filter: blur(8px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}

.member-card__balance--positive {
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 12%, var(--surface)), color-mix(in srgb, var(--surface) 96%, transparent));
  border-color: var(--accent-glow);
}

.member-card__balance--negative {
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 12%, var(--surface)), color-mix(in srgb, var(--surface) 96%, transparent));
  border-color: rgba(255, 92, 106, 0.25);
}

.member-card__balance--neutral {
  background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 8%, var(--surface)), color-mix(in srgb, var(--surface) 96%, transparent));
  border-color: color-mix(in srgb, var(--blue) 18%, var(--border));
}

.member-card__balance-label {
  margin-bottom: 8px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.member-card__balance-value {
  color: var(--text);
  font-size: 30px;
  font-weight: 900;
  letter-spacing: -1.2px;
  line-height: 1;
}

.member-card__meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.member-card__meta-item {
  padding: 13px 14px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, transparent), color-mix(in srgb, var(--surface-elevated) 90%, transparent));
}

.member-card__meta-label {
  display: block;
  margin-bottom: 4px;
  color: var(--text-muted);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.member-card__meta-value {
  color: var(--text);
  font-size: 13px;
  font-weight: 800;
}

.member-card__actions {
  position: absolute;
  left: 14px;
  right: 14px;
  bottom: 14px;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  padding: 10px;
  border-radius: 20px;
  border: 1px solid color-mix(in srgb, var(--member-accent) 16%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-elevated) 94%, transparent), color-mix(in srgb, var(--surface) 92%, transparent)),
    linear-gradient(135deg, color-mix(in srgb, var(--member-accent) 6%, transparent), transparent 60%);
  backdrop-filter: blur(12px);
  transform: translateY(16px);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.26s ease, opacity 0.26s ease;
}

.member-card:hover .member-card__actions,
.member-card:focus-within .member-card__actions {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.member-action-btn {
  min-height: 40px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transform: translateY(0);
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, background-color 0.22s ease, color 0.22s ease;
}

.member-action-btn:hover {
  transform: translateY(-2px);
}

.member-action-btn--secondary {
  background: linear-gradient(135deg, color-mix(in srgb, var(--blue) 16%, transparent), color-mix(in srgb, var(--surface) 92%, transparent));
  border-color: color-mix(in srgb, var(--blue) 26%, transparent);
  color: var(--blue);
  box-shadow: 0 12px 20px color-mix(in srgb, var(--blue) 12%, transparent);
}

.member-action-btn--secondary:hover {
  box-shadow: 0 18px 28px color-mix(in srgb, var(--blue) 18%, transparent);
}

.member-action-btn--danger {
  background: linear-gradient(135deg, color-mix(in srgb, var(--red) 14%, transparent), color-mix(in srgb, var(--surface) 92%, transparent));
  border-color: rgba(255, 92, 106, 0.28);
  color: var(--red);
  box-shadow: 0 12px 20px color-mix(in srgb, var(--red) 12%, transparent);
}

.member-action-btn--danger:hover {
  box-shadow: 0 18px 28px color-mix(in srgb, var(--red) 18%, transparent);
}

.member-action-btn--full {
  grid-column: 1 / -1;
}

.members-empty {
  position: relative;
  overflow: hidden;
  padding: 72px 28px;
  border-radius: 30px;
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow-md);
  text-align: center;
}

.members-empty__glow {
  position: absolute;
  width: 220px;
  height: 220px;
  left: 50%;
  top: -120px;
  transform: translateX(-50%);
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 16%, transparent);
  filter: blur(18px);
}

.members-empty__icon,
.members-empty__title,
.members-empty__text,
.members-empty .members-btn {
  position: relative;
  z-index: 1;
}

.members-empty__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 84px;
  padding: 0 20px;
  height: 84px;
  border-radius: 26px;
  margin-bottom: 18px;
  background: var(--button-primary-gradient);
  color: var(--button-primary-text);
  font-size: 18px;
  font-weight: 900;
  letter-spacing: 1px;
  box-shadow: 0 20px 40px color-mix(in srgb, var(--accent) 18%, transparent);
}

.members-empty__title {
  margin: 0 0 8px;
  color: var(--text);
  font-size: 26px;
  font-weight: 900;
  letter-spacing: -0.8px;
}
                    
.members-empty__text {
  max-width: 420px;
  margin: 0 auto 24px;
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.7;
}

.app-modal__backdrop {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 24px 16px;
  background: var(--overlay);
  backdrop-filter: blur(14px);
  animation: fadeIn .2s ease;
  overflow-y: auto;
}

.app-modal {
  position: relative;
  max-height: 90vh;
  overflow-y: auto;
  margin: auto 0;
  padding: 28px;
  border-radius: 24px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--accent) 8%, transparent), transparent 28%);
  box-shadow: var(--shadow-md);
  animation: slideUp .25s ease;
}

.app-modal__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 20px;
}

.app-modal__title {
  margin: 0;
  color: var(--text);
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
  font-size: clamp(28px, 4vw, 34px);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.08;
}

.app-modal__close {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 94%, transparent);
  color: var(--text-muted);
  font-size: 22px;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
}

.app-modal__close-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.45s ease, color 0.2s ease;
  transform-origin: center;
}

.app-modal__close:hover {
  transform: translateY(-1px);
  color: var(--text);
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
  box-shadow: 0 14px 26px color-mix(in srgb, var(--bg) 18%, transparent);
}

.app-modal__body {
  display: grid;
  gap: 16px;
}

.app-modal__message {
  margin: 0 0 4px;
  color: var(--text-dim);
  font-size: 15px;
  font-weight: 500;
  line-height: 1.7;
}

.app-modal__actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.app-modal__action {
  min-height: 46px;
  padding: 0 18px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.01em;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
}

.app-modal__action:hover {
  transform: translateY(-1px);
}

.app-modal__action--secondary {
  background: color-mix(in srgb, var(--surface) 96%, transparent);
  border-color: var(--border);
  color: var(--text-dim);
  box-shadow: 0 12px 24px color-mix(in srgb, var(--bg) 12%, transparent);
}

.app-modal__action--secondary:hover {
  color: var(--text);
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
}

.app-modal__action--danger {
  background: linear-gradient(135deg, #FF6472, #E24359);
  color: #FFFFFF;
  box-shadow: 0 16px 30px color-mix(in srgb, var(--red) 26%, transparent);
}

.app-modal__action--danger:hover {
  box-shadow: 0 20px 34px color-mix(in srgb, var(--red) 30%, transparent);
}

.app-modal__action--accent {
  background: var(--button-accent-gradient);
  color: var(--button-accent-text);
  box-shadow: 0 16px 30px color-mix(in srgb, var(--blue) 24%, transparent);
}

.app-modal__action--accent:hover {
  box-shadow: 0 20px 34px color-mix(in srgb, var(--blue) 28%, transparent);
}

.app-modal__action:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

[data-theme="light"] .app-modal {
  border-color: #D2DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.98)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 28%);
  box-shadow:
    0 24px 56px rgba(19, 37, 71, 0.16),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .app-modal__title {
  color: #16263D;
}

[data-theme="light"] .app-modal__message {
  color: #4C5F78;
}

[data-theme="light"] .app-modal__close {
  border-color: #D0DBE8;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #74859C;
  box-shadow: 0 12px 24px rgba(30, 55, 95, 0.08);
}

[data-theme="light"] .app-modal__close:hover {
  color: #18304D;
  border-color: rgba(47, 118, 222, 0.24);
  background: linear-gradient(180deg, #FFFFFF, #ECF4FF);
  box-shadow: 0 16px 30px rgba(30, 55, 95, 0.12);
}

[data-theme="light"] .app-modal__action--secondary {
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  border-color: #D0DBE8;
  color: #62748D;
  box-shadow: 0 12px 24px rgba(30, 55, 95, 0.08);
}

[data-theme="light"] .app-modal__action--secondary:hover {
  color: #18304D;
  background: linear-gradient(180deg, #FFFFFF, #EDF5FF);
}

[data-theme="light"] .app-modal__action--danger {
  background: linear-gradient(135deg, #FF6173, #E64458);
  box-shadow: 0 18px 34px rgba(230, 68, 88, 0.24);
}

[data-theme="light"] .app-modal__action--accent {
  background: linear-gradient(135deg, #3F86E8, #275FC0);
  box-shadow: 0 18px 34px rgba(47, 118, 222, 0.24);
}

@media (max-width: 640px) {
  .app-modal {
    padding: 22px;
    border-radius: 22px;
  }

  .app-modal__title {
    font-size: 24px;
  }

  .app-modal__actions {
    grid-template-columns: 1fr;
  }
}

.balances-page {
  display: grid;
  gap: 22px;
}

.balances-hero {
  position: relative;
  overflow: hidden;
  padding: 28px;
  border-radius: 28px;
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--border));
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 12%, transparent), transparent 42%),
    radial-gradient(circle at bottom right, color-mix(in srgb, var(--blue) 10%, transparent), transparent 38%),
    linear-gradient(145deg, color-mix(in srgb, var(--surface-alt) 94%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow-md);
}

.balances-hero--danger {
  border-color: color-mix(in srgb, var(--red) 18%, var(--border));
}

.balances-hero--positive {
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
}

.balances-hero--info {
  border-color: color-mix(in srgb, var(--blue) 20%, var(--border));
}

.balances-hero__bg {
  position: absolute;
  border-radius: 999px;
  filter: blur(14px);
  pointer-events: none;
}

.balances-hero__bg--left {
  top: -120px;
  left: -90px;
  width: 240px;
  height: 240px;
  background: color-mix(in srgb, var(--accent) 16%, transparent);
}

.balances-hero__bg--right {
  right: -90px;
  bottom: -120px;
  width: 220px;
  height: 220px;
  background: color-mix(in srgb, var(--blue) 15%, transparent);
}

.balances-hero__content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18px;
  flex-wrap: wrap;
}

.balances-hero__copy {
  max-width: 700px;
}

.balances-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  margin-bottom: 10px;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.balances-hero__title {
  margin: 0;
  color: var(--text);
  font-size: clamp(30px, 5vw, 44px);
  font-weight: 900;
  letter-spacing: -1.4px;
}

.balances-hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

.balances-chip {
  display: inline-flex;
  align-items: center;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, transparent);
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 700;
}

.balances-chip--positive {
  border-color: var(--accent-glow);
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--accent);
}

.balances-chip--danger {
  border-color: color-mix(in srgb, var(--red) 26%, transparent);
  background: color-mix(in srgb, var(--red) 12%, transparent);
  color: var(--red);
}

.balances-chip--info {
  border-color: color-mix(in srgb, var(--blue) 24%, transparent);
  background: color-mix(in srgb, var(--blue) 12%, transparent);
  color: var(--blue);
}

.balances-hero__summary,
.balances-hero__spotlight {
  min-width: min(100%, 300px);
  padding: 18px 20px;
  border-radius: 22px;
  border: 1px solid color-mix(in srgb, var(--accent) 14%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 95%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    linear-gradient(135deg, color-mix(in srgb, var(--accent) 6%, transparent), transparent 60%);
  box-shadow: 0 16px 34px color-mix(in srgb, var(--bg) 20%, transparent);
}

.balances-hero__summary-label,
.balances-focus__panel-label {
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
}

.balances-hero__summary-value,
.balances-hero__spotlight-value,
.balances-focus__panel-value {
  margin-top: 10px;
  color: var(--text);
  font-size: clamp(26px, 4vw, 36px);
  font-weight: 900;
  letter-spacing: -1.2px;
  line-height: 1;
}

.balances-hero__summary-note,
.balances-focus__panel-note {
  margin-top: 10px;
  color: var(--text-dim);
  font-size: 12px;
  line-height: 1.6;
}

.balances-hero__spotlight {
  display: flex;
  align-items: center;
  gap: 14px;
}

.balances-hero__spotlight--danger {
  border-color: color-mix(in srgb, var(--red) 22%, var(--border));
}

.balances-hero__spotlight--positive {
  border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
}

.balances-hero__spotlight--info {
  border-color: color-mix(in srgb, var(--blue) 22%, var(--border));
}

.balances-hero__spotlight-copy {
  display: grid;
  gap: 6px;
}

.balances-hero__spotlight-name {
  color: var(--text);
  font-size: 15px;
  font-weight: 800;
}

.balances-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 14px;
}

.balances-stat {
  padding: 20px 18px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow);
}

.balances-stat--positive {
  border-color: var(--accent-glow);
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-stat--danger {
  border-color: color-mix(in srgb, var(--red) 26%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-stat--warning {
  border-color: color-mix(in srgb, var(--yellow) 26%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--yellow) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-stat--info {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-stat__label {
  margin-bottom: 10px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.balances-stat__value {
  color: var(--text);
  font-size: 28px;
  font-weight: 900;
  letter-spacing: -1px;
}

.balances-stat__hint {
  margin-top: 8px;
  color: var(--text-dim);
  font-size: 12px;
}

.balances-section {
  padding: 22px;
  border-radius: 28px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow);
}

.balances-section--focus {
  padding: 0;
  border: none;
  background: transparent;
  box-shadow: none;
}

.balances-section__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 14px;
  margin-bottom: 18px;
  flex-wrap: wrap;
}

.balances-section__title {
  margin: 0;
  color: var(--text);
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.8px;
}

.balances-section__hint {
  padding: 8px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 800;
}

.balances-focus {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.8fr);
  gap: 16px;
  padding: 22px;
  border-radius: 28px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 10%, transparent), transparent 38%),
    linear-gradient(160deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow-md);
}

.balances-focus--danger {
  border-color: color-mix(in srgb, var(--red) 24%, var(--border));
}

.balances-focus--positive {
  border-color: color-mix(in srgb, var(--accent) 24%, var(--border));
}

.balances-focus--info {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
}

.balances-focus__label {
  margin-bottom: 10px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
}

.balances-focus__title {
  margin: 0;
  color: var(--text);
  font-size: clamp(22px, 4vw, 30px);
  font-weight: 900;
  letter-spacing: -0.9px;
  line-height: 1.15;
}

.balances-focus__copy {
  margin-top: 12px;
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.7;
}

.balances-focus__panel {
  align-self: stretch;
  padding: 18px 20px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 96%, transparent);
}

.balances-members-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}

.balance-member-card {
  position: relative;
  overflow: hidden;
  min-height: 228px;
  perspective: 1400px;
  border-radius: 24px;
  border: 1px solid color-mix(in srgb, var(--balance-member-accent) 22%, var(--border));
  background:
    radial-gradient(circle at top right, color-mix(in srgb, var(--balance-member-accent) 15%, transparent), transparent 35%),
    linear-gradient(165deg, var(--balance-member-accent-soft), transparent 48%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: 0 16px 38px color-mix(in srgb, var(--bg) 20%, transparent);
  transition: border-color 0.28s ease, box-shadow 0.28s ease, transform 0.28s ease;
}

.balance-member-card:hover,
.balance-member-card:focus-within {
  transform: translateY(-4px);
  border-color: color-mix(in srgb, var(--balance-member-accent) 36%, var(--border));
  box-shadow: 0 24px 48px color-mix(in srgb, var(--balance-member-accent) 18%, transparent);
}

.balance-member-card__inner {
  position: relative;
  width: 100%;
  min-height: 228px;
  transform-style: preserve-3d;
  transition: transform 0.7s cubic-bezier(.2, .75, .2, 1);
}

.balance-member-card:hover .balance-member-card__inner,
.balance-member-card:focus-within .balance-member-card__inner {
  transform: rotateY(180deg);
}

.balance-member-card__face {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 16px;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.balance-member-card__face--front {
  justify-content: flex-start;
}

.balance-member-card__face--back {
  transform: rotateY(180deg);
  justify-content: flex-start;
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--balance-member-accent) 14%, transparent), transparent 38%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 97%, transparent), color-mix(in srgb, var(--surface-elevated) 94%, transparent));
}

.balance-member-card__header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: start;
  gap: 10px;
  margin-bottom: 10px;
}

.balance-member-card__identity {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: start;
  gap: 14px;
  min-width: 0;
}

.balance-member-card__copy {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.balance-member-card__name {
  margin: 0;
  color: var(--text);
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -0.6px;
  line-height: 1.15;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.balance-member-card__email {
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: normal;
  overflow-wrap: normal;
}

.balance-member-card__status {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  min-height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 118px;
}

.balance-member-card__status--positive {
  border: 1px solid var(--accent-glow);
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--accent);
}

.balance-member-card__status--danger {
  border: 1px solid color-mix(in srgb, var(--red) 26%, transparent);
  background: color-mix(in srgb, var(--red) 12%, transparent);
  color: var(--red);
}

.balance-member-card__status--info {
  border: 1px solid color-mix(in srgb, var(--blue) 24%, transparent);
  background: color-mix(in srgb, var(--blue) 12%, transparent);
  color: var(--blue);
}

.balance-member-card__amount {
  margin-top: 8px;
  padding: 16px 16px 14px;
  border-radius: 18px;
  border: 1px solid color-mix(in srgb, var(--balance-member-accent) 18%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    linear-gradient(135deg, color-mix(in srgb, var(--balance-member-accent) 6%, transparent), transparent 60%);
}

.balance-member-card__amount--positive {
  border-color: var(--accent-glow);
}

.balance-member-card__amount--danger {
  border-color: color-mix(in srgb, var(--red) 26%, var(--border));
}

.balance-member-card__amount--info {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
}

.balance-member-card__amount-label {
  margin-bottom: 8px;
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.balance-member-card__amount-value {
  color: var(--text);
  font-size: 30px;
  font-weight: 900;
  letter-spacing: -1.2px;
  line-height: 1;
}

.balance-member-card__back-admin {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 18px;
  border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--accent) 8%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    color-mix(in srgb, var(--surface) 94%, transparent);
}

.balance-member-card__back-admin-copy {
  min-width: 0;
  display: grid;
  gap: 5px;
}

.balance-member-card__back-admin-label {
  color: var(--text-muted);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
}

.balance-member-card__back-admin-name {
  color: var(--text);
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.15;
}

.balance-member-card__back-grid {
  display: grid;
  gap: 10px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-content: start;
}

.balance-member-card__back-panel {
  display: grid;
  gap: 5px;
  padding: 12px 14px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent));
  min-height: 74px;
  align-content: start;
}

.balance-member-card__meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: auto;
}

.balance-member-card__meta-item {
  padding: 13px 14px;
  border-radius: 18px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, transparent), color-mix(in srgb, var(--surface-elevated) 90%, transparent));
}

.balance-member-card__meta-label {
  display: block;
  margin-bottom: 4px;
  color: var(--text-muted);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.balance-member-card__meta-value {
  color: var(--text);
  font-size: 13px;
  font-weight: 800;
}

.balances-settlement-list {
  display: grid;
  gap: 10px;
}

.balances-settlement-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 16px;
  padding: 18px 20px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 97%, transparent), color-mix(in srgb, var(--surface-elevated) 94%, transparent));
}

.balances-settlement-item__parties {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  gap: 14px;
  min-width: 0;
}

.balances-settlement-party {
  min-width: 0;
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 94%, transparent);
}

.balances-settlement-party--from {
  border-color: color-mix(in srgb, var(--red) 20%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 8%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-settlement-party--to {
  border-color: color-mix(in srgb, var(--accent) 20%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 8%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.balances-settlement-party__label {
  margin-bottom: 6px;
  color: var(--text-muted);
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
}

.balances-settlement-party__name {
  color: var(--text);
  font-size: 15px;
  font-weight: 800;
  line-height: 1.35;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.balances-settlement-party--from .balances-settlement-party__name {
  color: var(--red);
}

.balances-settlement-party--to .balances-settlement-party__name {
  color: var(--accent);
}

.balances-settlement-item__connector {
  display: flex;
  align-items: center;
  gap: 8px;
  min-width: 88px;
}

.balances-settlement-item__arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--blue) 14%, var(--border));
  background: color-mix(in srgb, var(--surface) 94%, transparent);
  color: var(--text-muted);
  font-size: 14px;
  font-weight: 800;
  flex-shrink: 0;
}

.balances-settlement-item__line {
  width: 26px;
  height: 1px;
  background: color-mix(in srgb, var(--blue) 16%, var(--border));
}

.balances-settlement-item__amount {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  min-width: 132px;
  padding: 0 18px;
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--blue) 16%, var(--border));
  background: color-mix(in srgb, var(--surface) 98%, transparent);
  color: var(--text);
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.8px;
  white-space: nowrap;
}

.balances-settled-empty {
  padding: 28px;
  border-radius: 22px;
  border: 1px solid var(--accent-glow);
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
  text-align: center;
}

.balances-settled-empty__title {
  color: var(--accent);
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -0.5px;
}

.balances-settled-empty__copy {
  margin-top: 6px;
  color: var(--text-dim);
  font-size: 13px;
}

.payments-page {
  display: grid;
  gap: 18px;
}

.payments-hero {
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.9fr);
  gap: 18px;
  padding: 20px;
  border-radius: 26px;
  border: 1px solid color-mix(in srgb, var(--blue) 18%, var(--border));
  background:
    radial-gradient(circle at 0% 0%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 30%),
    radial-gradient(circle at 100% 100%, color-mix(in srgb, var(--blue) 18%, transparent), transparent 34%),
    linear-gradient(135deg, color-mix(in srgb, #0D1119 92%, var(--surface)) 0%, color-mix(in srgb, #111B2C 88%, var(--surface)) 52%, color-mix(in srgb, #16101F 86%, var(--surface)) 100%);
  box-shadow: var(--shadow-md);
}

.payments-hero__copy {
  display: grid;
  align-content: start;
  gap: 10px;
}

.payments-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-self: flex-start;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--blue) 30%, var(--border));
  background: color-mix(in srgb, var(--surface) 82%, transparent);
  color: color-mix(in srgb, var(--blue) 86%, white);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.payments-hero__title {
  margin: 0;
  color: #F4F7FB;
  font-size: clamp(28px, 4.4vw, 42px);
  font-weight: 900;
  letter-spacing: -1.2px;
}

.payments-hero__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.payments-chip {
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--surface) 70%, var(--border));
  background: color-mix(in srgb, var(--surface) 82%, transparent);
  color: #B6C1D6;
  font-size: 11px;
  font-weight: 700;
}

.payments-chip--accent {
  border-color: color-mix(in srgb, var(--accent) 28%, transparent);
  color: #69E2BC;
}

.payments-chip--success {
  border-color: color-mix(in srgb, var(--accent) 24%, transparent);
  color: var(--accent);
}

.payments-chip--danger {
  border-color: color-mix(in srgb, var(--red) 28%, transparent);
  color: #FF8591;
}

.payments-hero__aside {
  display: grid;
  gap: 12px;
}

.payments-hero__ledger {
  display: grid;
  gap: 8px;
  padding: 12px;
  border-radius: 18px;
  border: 1px solid color-mix(in srgb, var(--surface) 76%, var(--border));
  background: color-mix(in srgb, var(--surface) 86%, transparent);
  backdrop-filter: blur(12px);
}

.payments-hero__ledger-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  padding: 8px 10px;
  border-radius: 14px;
  background: color-mix(in srgb, var(--surface) 92%, transparent);
}

.payments-hero__ledger-label {
  color: #9EABC5;
  font-size: 11px;
  font-weight: 700;
}

.payments-hero__ledger-value {
  color: #F5F7FB;
  font-size: 16px;
  font-weight: 900;
  letter-spacing: -0.4px;
}

.payments-hero__actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.payments-action {
  min-height: 42px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: -0.01em;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.payments-action:hover {
  transform: translateY(-1px);
}

.payments-action--primary {
  background: linear-gradient(135deg, #2ECC9A 0%, #159F7A 100%);
  color: #05251A;
  box-shadow: 0 16px 32px rgba(46, 204, 154, 0.18);
}

.payments-action--secondary {
  background: linear-gradient(135deg, #5F8FFF 0%, #4774E0 100%);
  color: #FFFFFF;
  box-shadow: 0 16px 32px rgba(95, 143, 255, 0.18);
}

.payments-overview {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(180px, 1fr));
  gap: 12px;
}

.payments-overview-card {
  position: relative;
  overflow: hidden;
  min-height: 126px;
  padding: 16px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 34%);
  box-shadow: var(--shadow);
}

.payments-overview-card--featured {
  min-height: 138px;
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 14%, transparent), transparent 34%),
    linear-gradient(145deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.payments-overview-card--success {
  border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
}

.payments-overview-card--info {
  border-color: color-mix(in srgb, var(--blue) 22%, var(--border));
}

.payments-overview-card--danger {
  border-color: color-mix(in srgb, var(--red) 24%, var(--border));
}

.payments-overview-card__label {
  color: var(--text-muted);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.85px;
  text-transform: uppercase;
}

.payments-overview-card__value {
  margin-top: 12px;
  color: var(--text);
  font-size: clamp(24px, 3.6vw, 34px);
  font-weight: 900;
  letter-spacing: -1px;
  line-height: 1;
}

.payments-overview-card__note {
  margin-top: 10px;
  color: var(--text-dim);
  font-size: 12px;
  line-height: 1.5;
}

.payments-panel {
  border-radius: 24px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 7%, transparent), transparent 30%);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.payments-panel__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14px;
  padding: 16px 18px 14px;
  border-bottom: 1px solid color-mix(in srgb, var(--blue) 10%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, transparent), color-mix(in srgb, var(--surface-alt) 88%, transparent)),
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 5%, transparent), transparent 24%);
  flex-wrap: wrap;
}

.payments-panel__title {
  margin: 0;
  color: var(--text);
  font-size: 21px;
  font-weight: 900;
  letter-spacing: -0.8px;
}

.payments-tabs {
  display: inline-flex;
  gap: 8px;
  padding: 6px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--blue) 12%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 92%, transparent), color-mix(in srgb, var(--surface-alt) 86%, transparent));
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.02);
}

.payments-tab {
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--text-muted);
  font-size: 12px;
  font-weight: 700;
}

.payments-tab--active {
  background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 18%, transparent), color-mix(in srgb, var(--surface) 96%, transparent));
  border-color: color-mix(in srgb, var(--accent) 26%, transparent);
  color: var(--accent);
  box-shadow: 0 10px 22px color-mix(in srgb, var(--accent) 12%, transparent);
}

.payments-feed {
  display: grid;
  gap: 12px;
  padding: 14px;
}

.payment-entry {
  position: relative;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  padding: 15px 16px;
  border: 1px solid color-mix(in srgb, var(--blue) 10%, var(--border));
  border-radius: 20px;
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 97%, transparent), color-mix(in srgb, var(--surface-alt) 92%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 6%, transparent), transparent 28%);
  box-shadow: 0 14px 30px color-mix(in srgb, var(--bg) 14%, transparent);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.payment-entry:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 34px color-mix(in srgb, var(--bg) 18%, transparent);
}

.payment-entry::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16px;
  bottom: 16px;
  width: 3px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--blue) 34%, transparent);
}

.payment-entry--success::before {
  background: color-mix(in srgb, var(--accent) 42%, transparent);
}

.payment-entry--info::before {
  background: color-mix(in srgb, var(--blue) 42%, transparent);
}

.payment-entry--success {
  border-color: color-mix(in srgb, var(--accent) 16%, var(--border));
}

.payment-entry--info {
  border-color: color-mix(in srgb, var(--blue) 16%, var(--border));
}

.payment-entry__left {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  min-width: 0;
}

.payment-entry__copy {
  min-width: 0;
  display: grid;
  gap: 6px;
}

.payment-entry__topline {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
}

.payment-entry__name {
  margin: 0;
  color: var(--text);
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -0.3px;
  line-height: 1.2;
}

.payment-entry__chip {
  display: inline-flex;
  align-items: center;
  min-height: 22px;
  padding: 0 8px;
  border-radius: 999px;
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  align-self: center;
}

.payment-entry__chip--success {
  border: 1px solid var(--accent-glow);
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--accent);
}

.payment-entry__chip--info {
  border: 1px solid color-mix(in srgb, var(--blue) 26%, transparent);
  background: color-mix(in srgb, var(--blue) 12%, transparent);
  color: var(--blue);
}

.payment-entry__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 12px;
  color: var(--text-muted);
  font-size: 11px;
  line-height: 1.4;
}

.payment-entry__meta span {
  position: relative;
}

.payment-entry__meta span:not(:last-child)::after {
  content: "";
  position: absolute;
  right: -8px;
  top: 50%;
  width: 4px;
  height: 4px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--text-muted) 40%, transparent);
  transform: translateY(-50%);
}

.payment-entry__right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.payment-entry__amount {
  min-height: 40px;
  padding: 0 14px;
  border-radius: 14px;
  border: 1px solid var(--border);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -0.6px;
  white-space: nowrap;
}

.payment-entry__amount--success {
  border-color: color-mix(in srgb, var(--accent) 24%, var(--border));
  color: var(--accent);
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.payment-entry__amount--info {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
  color: var(--blue);
  background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 10%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.payment-entry__reverse {
  min-height: 34px;
  padding: 0 12px;
  border-radius: 10px;
  border: 1px solid color-mix(in srgb, var(--red) 20%, transparent);
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 10%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  color: var(--red);
  font-size: 11px;
  font-weight: 800;
}

.payments-panel__footer {
  padding: 12px 16px;
  border-top: 1px solid color-mix(in srgb, var(--blue) 10%, var(--border));
}

.payments-empty {
  padding: 72px 28px;
  border-radius: 30px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top, color-mix(in srgb, var(--accent) 14%, transparent), transparent 30%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow-md);
  text-align: center;
}

.payments-empty__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96px;
  height: 96px;
  margin-bottom: 18px;
  border-radius: 28px;
  background: linear-gradient(135deg, #2ECC9A, #4774E0);
  color: #08131D;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: 1px;
  box-shadow: 0 18px 40px rgba(71, 116, 224, 0.18);
}

.payments-empty__title {
  margin: 0;
  color: var(--text);
  font-size: 28px;
  font-weight: 900;
  letter-spacing: -0.8px;
}

.payments-empty__copy {
  margin: 8px auto 24px;
  max-width: 420px;
  color: var(--text-dim);
  font-size: 14px;
  line-height: 1.7;
}

.payments-form {
  display: grid;
  gap: 0;
}

.payments-modal {
  max-width: 560px !important;
  max-height: none;
  overflow: visible;
  border-radius: 28px;
  border-color: color-mix(in srgb, var(--blue) 16%, var(--border));
  background:
    linear-gradient(180deg, rgba(12, 17, 29, 0.96), rgba(17, 24, 39, 0.92)),
    radial-gradient(circle at top left, rgba(44, 204, 154, 0.10), transparent 28%),
    radial-gradient(circle at bottom right, rgba(83, 121, 255, 0.12), transparent 32%);
  backdrop-filter: blur(24px);
  box-shadow:
    0 28px 80px rgba(5, 8, 18, 0.56),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

.payments-modal .app-modal__header {
  margin-bottom: 16px;
  padding: 14px;
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.08);
  background:
    radial-gradient(circle at top left, rgba(46, 204, 154, 0.12), transparent 26%),
    radial-gradient(circle at top right, rgba(95, 143, 255, 0.14), transparent 30%),
    linear-gradient(135deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.04),
    0 16px 32px rgba(7, 10, 18, 0.22);
}

.payments-modal .app-modal__title {
  font-size: clamp(20px, 3.4vw, 28px);
  letter-spacing: -0.05em;
  color: #F5F7FB;
}

.payments-modal__title-group {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.payments-modal__logo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid rgba(255,255,255,0.10);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.08em;
  flex-shrink: 0;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.06),
    0 14px 28px rgba(5, 8, 18, 0.18);
}

.payments-modal__logo--primary {
  background: linear-gradient(135deg, rgba(46, 204, 154, 0.20), rgba(12, 40, 31, 0.95));
  color: #70E3BF;
}

.payments-modal__logo--accent {
  background: linear-gradient(135deg, rgba(95, 143, 255, 0.22), rgba(14, 27, 58, 0.95));
  color: #8CB2FF;
}

.payments-modal__title-text {
  display: inline-block;
  background: linear-gradient(90deg, #F8FAFC 0%, #9FE6D0 45%, #91B5FF 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  white-space: nowrap;
}

.payments-modal .app-modal__close {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.08);
  color: #B4C0D3;
}

.payments-modal .app-modal__close:hover {
  color: #FF7A87;
  border-color: rgba(255, 92, 106, 0.28);
  background: linear-gradient(180deg, rgba(255, 92, 106, 0.10), rgba(255, 255, 255, 0.03));
  box-shadow: 0 16px 30px rgba(255, 92, 106, 0.14);
}

.payments-modal .app-modal__close:hover .app-modal__close-icon {
  transform: rotate(360deg);
  color: #FF6B79;
}

.payments-form__surface {
  display: grid;
  gap: 16px;
  padding: 8px 2px 2px;
  overflow: visible;
  isolation: isolate;
}

.payments-form__intro {
  display: grid;
  gap: 10px;
  padding: 18px 18px 16px;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 12%, transparent), transparent 30%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
}

.payments-form__intro--member {
  border-color: rgba(46, 204, 154, 0.14);
}

.payments-form__intro--self {
  border-color: rgba(91, 141, 239, 0.16);
}

.payments-form__intro-badge {
  display: inline-flex;
  align-items: center;
  justify-self: flex-start;
  min-height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(9, 14, 24, 0.42);
  color: #B7C3D6;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.payments-form__intro-title {
  color: #F4F7FB;
  font-size: 22px;
  font-weight: 900;
  letter-spacing: -0.04em;
}

.payments-form__intro-copy {
  color: #9DA9BC;
  font-size: 13px;
  line-height: 1.7;
}

.payments-form__intro-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid rgba(91, 141, 239, 0.18);
  background: rgba(10, 16, 28, 0.48);
  color: #A8B5C9;
  font-size: 12px;
}

.payments-form__intro-meta strong {
  color: #7EA9FF;
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -0.4px;
}

.payments-form__section {
  position: relative;
  z-index: 1;
  overflow: visible;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
    rgba(9, 14, 24, 0.34);
  backdrop-filter: blur(14px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}

.payments-form__section:has(.payments-floating-select--open) {
  z-index: 80;
}

.payments-form__split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.payments-floating-field {
  margin-bottom: 14px;
}

.payments-floating-field:last-child {
  margin-bottom: 0;
}

.payments-floating-field__control {
  position: relative;
}

.payments-floating-field__icon {
  position: absolute;
  left: 16px;
  top: 50%;
  width: 18px;
  height: 18px;
  color: #7D8AA0;
  transform: translateY(-50%);
  pointer-events: none;
  transition: color 0.24s ease, transform 0.24s ease;
}

.payments-floating-field__icon-svg {
  width: 18px;
  height: 18px;
  display: block;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.payments-floating-field__label {
  position: absolute;
  left: 46px;
  top: 50%;
  color: #95A1B5;
  font-size: 13px;
  font-weight: 600;
  pointer-events: none;
  transform: translateY(-50%);
  transform-origin: left top;
  transition: transform 0.24s ease, color 0.24s ease, top 0.24s ease;
}

.payments-floating-field__required {
  margin-left: 4px;
  color: #FF7C88;
}

.payments-floating-field__input {
  width: 100%;
  min-height: 58px;
  padding: 28px 16px 10px 46px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.08);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02)),
    rgba(7, 11, 19, 0.42);
  color: #E5E7EB;
  font-size: 14px;
  font-weight: 600;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  transition: border-color 0.24s ease, box-shadow 0.24s ease, transform 0.24s ease, background-color 0.24s ease;
}

.payments-floating-field__input::placeholder {
  color: transparent;
}

.payments-floating-field__input:hover {
  border-color: rgba(255,255,255,0.12);
}

.payments-floating-field__input:focus {
  border-color: rgba(46, 204, 154, 0.34);
  box-shadow: 0 0 0 4px rgba(46, 204, 154, 0.10), 0 12px 30px rgba(46, 204, 154, 0.08);
  transform: translateY(-1px);
}

.payments-floating-field__input--button {
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  cursor: pointer;
}

.payments-floating-field__input--select {
  appearance: none;
  background-image:
    linear-gradient(45deg, transparent 50%, #91A0B6 50%),
    linear-gradient(135deg, #91A0B6 50%, transparent 50%);
  background-position:
    calc(100% - 22px) calc(50% + 2px),
    calc(100% - 16px) calc(50% + 2px);
  background-size: 6px 6px, 6px 6px;
  background-repeat: no-repeat;
  padding-right: 42px;
}

.payments-floating-field__input--textarea {
  min-height: 108px;
  padding-top: 32px;
  resize: vertical;
}

.payments-floating-field__control:focus-within .payments-floating-field__icon,
.payments-floating-field--filled .payments-floating-field__icon {
  color: #65DAB2;
}

.payments-floating-field__control:focus-within .payments-floating-field__label,
.payments-floating-field--filled .payments-floating-field__label,
.payments-floating-field__input:not(:placeholder-shown) + .payments-floating-field__label {
  top: 12px;
  transform: translateY(0) scale(0.82);
  color: #65DAB2;
}

.payments-floating-field__hint {
  margin-top: 8px;
  padding-left: 2px;
  color: #7F8CA0;
  font-size: 12px;
  line-height: 1.5;
}

.payments-floating-select {
  position: relative;
  z-index: 2;
}

.payments-floating-select--open {
  z-index: 40;
}

.payments-floating-select__value {
  display: flex;
  align-items: center;
  min-width: 0;
  color: #E5E7EB;
}

.payments-floating-select__value--placeholder {
  color: #A4B0C3;
}

.payments-floating-select__chevron {
  width: 10px;
  height: 10px;
  border-right: 2px solid #94A3B8;
  border-bottom: 2px solid #94A3B8;
  transform: rotate(45deg);
  transition: transform 0.24s ease, border-color 0.24s ease;
  flex-shrink: 0;
  margin-left: 12px;
}

.payments-floating-select--open .payments-floating-select__chevron {
  transform: rotate(-135deg) translateY(-1px);
  border-color: #65DAB2;
}

.payments-floating-select__menu {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  right: 0;
  z-index: 50;
  display: grid;
  gap: 8px;
  padding: 10px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.10);
  background:
    linear-gradient(180deg, rgba(11, 16, 27, 0.96), rgba(15, 21, 34, 0.94)),
    radial-gradient(circle at top right, rgba(46, 204, 154, 0.08), transparent 26%);
  box-shadow:
    0 26px 56px rgba(5, 8, 18, 0.48),
    inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(18px);
}

.payments-modal .app-modal__body {
  overflow: visible;
}

.payments-floating-select__menu--members {
  max-height: 250px;
  overflow-y: auto;
}

.payments-floating-date__trigger {
  justify-content: space-between;
}

.payments-floating-date__panel {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  z-index: 55;
  width: 286px;
  max-width: calc(100vw - 64px);
  padding: 10px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.10);
  background:
    linear-gradient(180deg, rgba(11, 16, 27, 0.98), rgba(15, 21, 34, 0.96)),
    radial-gradient(circle at top right, rgba(95, 143, 255, 0.10), transparent 28%);
  box-shadow:
    0 28px 60px rgba(5, 8, 18, 0.52),
    inset 0 1px 0 rgba(255,255,255,0.05);
  backdrop-filter: blur(18px);
}

.payments-floating-date__panel--up {
  top: auto;
  bottom: calc(100% + 10px);
}

.payments-floating-date__header {
  display: grid;
  grid-template-columns: 30px 1fr 30px;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
}

.payments-floating-date__month {
  color: #F5F7FB;
  font-size: 13px;
  font-weight: 800;
  text-align: center;
  letter-spacing: -0.03em;
}

.payments-floating-date__nav {
  width: 30px;
  height: 30px;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.22s ease, border-color 0.22s ease, background-color 0.22s ease;
}

.payments-floating-date__nav:hover {
  transform: translateY(-1px);
  border-color: rgba(95, 143, 255, 0.18);
  background: rgba(95, 143, 255, 0.10);
}

.payments-floating-date__nav-icon {
  width: 9px;
  height: 9px;
  border-top: 2px solid #AAB7CB;
  border-right: 2px solid #AAB7CB;
}

.payments-floating-date__nav-icon--left {
  transform: rotate(-135deg);
  margin-left: 4px;
}

.payments-floating-date__nav-icon--right {
  transform: rotate(45deg);
  margin-right: 4px;
}

.payments-floating-date__weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
  margin-bottom: 6px;
}

.payments-floating-date__weekday {
  color: #8FA0B8;
  font-size: 10px;
  font-weight: 700;
  text-align: center;
}

.payments-floating-date__grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}

.payments-floating-date__day {
  min-height: 34px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: rgba(255,255,255,0.02);
  color: #E5E7EB;
  font-size: 12px;
  font-weight: 700;
  transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
}

.payments-floating-date__day:hover {
  transform: translateY(-1px);
  border-color: rgba(95, 143, 255, 0.14);
  background: rgba(95, 143, 255, 0.10);
}

.payments-floating-date__day--muted {
  color: #67768D;
}

.payments-floating-date__day--today {
  border-color: rgba(46, 204, 154, 0.16);
  color: #71E4C0;
}

.payments-floating-date__day--selected {
  border-color: rgba(95, 143, 255, 0.24);
  background: linear-gradient(135deg, rgba(95, 143, 255, 0.24), rgba(71, 116, 224, 0.18));
  color: #FFFFFF;
  box-shadow: 0 12px 24px rgba(95, 143, 255, 0.18);
}

.payments-floating-select__option {
  width: 100%;
  padding: 10px 12px;
  border-radius: 16px;
  border: 1px solid transparent;
  background: rgba(255,255,255,0.03);
  transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
}

.payments-floating-select__option:hover {
  transform: translateY(-1px);
  border-color: rgba(46, 204, 154, 0.16);
  background: rgba(255,255,255,0.05);
}

.payments-floating-select__option--active {
  border-color: rgba(95, 143, 255, 0.20);
  background: linear-gradient(135deg, rgba(95, 143, 255, 0.16), rgba(255,255,255,0.04));
  box-shadow: 0 12px 24px rgba(95, 143, 255, 0.10);
}

.payments-floating-select__selected {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.payments-floating-select__selected--member {
  width: 100%;
  justify-content: space-between;
  gap: 12px;
}

.payments-floating-select__selected-copy,
.payments-floating-select__option-copy {
  display: grid;
  gap: 2px;
  min-width: 0;
}

.payments-floating-select__selected-copy--member,
.payments-floating-select__option-copy--member {
  flex: 1;
  justify-items: start;
  text-align: left;
}

.payments-floating-select__selected-label,
.payments-floating-select__option-label,
.payments-floating-select__simple-label,
.payments-floating-select__simple-value {
  color: #E5E7EB;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.35;
}

.payments-floating-select__selected-hint,
.payments-floating-select__option-hint {
  color: #92A0B6;
  font-size: 11px;
  line-height: 1.4;
}

.payments-floating-select__option-layout,
.payments-floating-select__simple-option {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  width: 100%;
  justify-content: space-between;
}

.payments-floating-select__option-main {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  flex: 1;
}

.payments-floating-select__avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  border: 1px solid color-mix(in srgb, var(--option-accent) 34%, transparent);
  background: linear-gradient(145deg, color-mix(in srgb, var(--option-accent) 22%, transparent), rgba(255,255,255,0.03));
  color: var(--option-accent);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.04em;
  flex-shrink: 0;
  box-shadow: 0 10px 20px color-mix(in srgb, var(--option-accent) 14%, transparent);
}

.payments-floating-select__status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.04);
  color: #B8C4D7;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.02em;
  white-space: nowrap;
  flex-shrink: 0;
}

.payments-floating-select__status--selected {
  min-height: 24px;
  padding: 0 8px;
  font-size: 9px;
}

.payments-floating-select__status--success {
  border-color: rgba(46, 204, 154, 0.18);
  background: rgba(46, 204, 154, 0.10);
  color: #73E4C0;
}

.payments-floating-select__status--danger {
  border-color: rgba(255, 92, 106, 0.18);
  background: rgba(255, 92, 106, 0.10);
  color: #FF93A0;
}

.payments-floating-select__status--neutral {
  border-color: rgba(148, 163, 184, 0.16);
  background: rgba(148, 163, 184, 0.08);
  color: #C1CAD8;
}

.payments-form__member-card {
  margin-top: 2px;
  margin-bottom: 0;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(7, 11, 19, 0.42);
}

.payments-form__member-card--due {
  border-color: rgba(255, 92, 106, 0.12);
  background: linear-gradient(180deg, rgba(255, 92, 106, 0.06), rgba(7, 11, 19, 0.44));
}

.payments-form__member-card--ok {
  border-color: rgba(46, 204, 154, 0.10);
  background: linear-gradient(180deg, rgba(46, 204, 154, 0.05), rgba(7, 11, 19, 0.44));
}

.payments-form__member-card-content {
  min-width: 0;
}

.payments-form__member-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.payments-form__member-card-name {
  color: #F4F7FB;
  font-size: 13px;
  font-weight: 800;
}

.payments-form__member-card-change {
  min-height: 28px;
  padding: 0 10px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.03);
  color: #B8C4D7;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}

.payments-form__member-card-copy {
  margin-top: 4px;
  color: #99A6BA;
  font-size: 11px;
  line-height: 1.45;
}

.payments-form__actions {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 12px;
}

.payments-form__action {
  min-height: 50px;
  padding: 0 18px;
  border-radius: 16px;
  border: 1px solid transparent;
  font-size: 14px;
  font-weight: 800;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, opacity 0.22s ease;
}

.payments-form__action:hover {
  transform: translateY(-1px);
}

.payments-form__action:active {
  transform: translateY(0) scale(0.985);
}

.payments-form__action:disabled {
  opacity: 0.65;
  cursor: not-allowed;
  transform: none;
}

.payments-form__action--secondary {
  border-color: rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.03);
  color: #B7C3D6;
}

.payments-form__action--primary {
  background: linear-gradient(135deg, #2ECC9A 0%, #129D79 100%);
  color: #041D14;
  box-shadow: 0 18px 36px rgba(46, 204, 154, 0.24);
}

.payments-form__action--accent {
  background: linear-gradient(135deg, #5F8FFF 0%, #4774E0 100%);
  color: #FFFFFF;
  box-shadow: 0 18px 36px rgba(95, 143, 255, 0.24);
}

[data-theme="light"] .payments-hero {
  border-color: #D3DDEA;
  background:
    radial-gradient(circle at 0% 0%, rgba(18, 168, 138, 0.18), transparent 30%),
    radial-gradient(circle at 100% 100%, rgba(59, 132, 232, 0.18), transparent 34%),
    linear-gradient(135deg, #FFFFFF 0%, #F4F8FD 46%, #EAF1FF 100%);
  box-shadow:
    0 24px 56px rgba(19, 37, 71, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .payments-hero__title {
  color: #14243A;
}

[data-theme="light"] .payments-hero__eyebrow {
  border-color: rgba(47, 118, 222, 0.18);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 252, 0.95));
  color: #2956A8;
}

[data-theme="light"] .payments-chip {
  border-color: #D3DDEA;
  background: rgba(255, 255, 255, 0.92);
  color: #5F7188;
}

[data-theme="light"] .payments-chip--accent {
  color: #0B6B58;
}

[data-theme="light"] .payments-chip--danger {
  color: #C53A4C;
}

[data-theme="light"] .payments-hero__ledger {
  border-color: #D3DDEA;
  background: rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .payments-hero__ledger-line {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 252, 0.95));
}

[data-theme="light"] .payments-hero__ledger-label {
  color: #687B93;
}

[data-theme="light"] .payments-hero__ledger-value {
  color: #14243A;
}

[data-theme="light"] .payments-action--primary {
  color: #F7FFFC;
}

[data-theme="light"] .payments-overview-card,
[data-theme="light"] .payments-panel,
[data-theme="light"] .payments-empty {
  border-color: #D3DDEA;
  box-shadow:
    0 16px 38px rgba(19, 37, 71, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.86);
}

[data-theme="light"] .payments-overview-card,
[data-theme="light"] .payments-panel {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.97)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.06), transparent 28%);
}

[data-theme="light"] .payments-overview-card__label,
[data-theme="light"] .payments-overview-card__note,
[data-theme="light"] .payment-entry__meta,
[data-theme="light"] .payments-empty__copy {
  color: #5D7088;
}

[data-theme="light"] .payments-form__intro,
[data-theme="light"] .payments-form__section {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.96)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.06), transparent 28%);
}

[data-theme="light"] .payments-modal {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(242,247,253,0.96)),
    radial-gradient(circle at top left, rgba(15, 159, 132, 0.10), transparent 28%),
    radial-gradient(circle at bottom right, rgba(59, 132, 232, 0.12), transparent 30%);
  box-shadow:
    0 28px 80px rgba(19, 37, 71, 0.16),
    inset 0 1px 0 rgba(255,255,255,0.88);
}

[data-theme="light"] .payments-modal .app-modal__title {
  color: #152235;
}

[data-theme="light"] .payments-modal .app-modal__close {
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  border-color: #D3DDEA;
}

[data-theme="light"] .payments-modal .app-modal__header {
  border-color: #D3DDEA;
  background:
    radial-gradient(circle at top left, rgba(15, 159, 132, 0.10), transparent 26%),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.12), transparent 30%),
    linear-gradient(135deg, rgba(255,255,255,0.98), rgba(244,248,253,0.95));
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.88),
    0 14px 28px rgba(19, 37, 71, 0.08);
}

[data-theme="light"] .payments-modal__logo {
  border-color: #D3DDEA;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.88),
    0 12px 24px rgba(19, 37, 71, 0.08);
}

[data-theme="light"] .payments-modal__logo--primary {
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.16), rgba(255,255,255,0.98));
  color: #0B6B58;
}

[data-theme="light"] .payments-modal__logo--accent {
  background: linear-gradient(135deg, rgba(59, 132, 232, 0.16), rgba(255,255,255,0.98));
  color: #2956A8;
}

[data-theme="light"] .payments-modal__title-text {
  background: linear-gradient(90deg, #12233A 0%, #0B6B58 46%, #2956A8 100%);
  -webkit-background-clip: text;
  background-clip: text;
}

[data-theme="light"] .payments-form__intro-badge,
[data-theme="light"] .payments-form__intro-meta,
[data-theme="light"] .payments-form__member-card,
[data-theme="light"] .payments-form__action--secondary {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .payments-floating-field__icon {
  color: #7A8CA4;
}

[data-theme="light"] .payments-floating-field__label {
  color: #7A8CA4;
}

[data-theme="light"] .payments-floating-field__input {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(244,248,252,0.95)),
    rgba(255,255,255,0.88);
  color: #152235;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.88),
    0 10px 22px rgba(19, 37, 71, 0.04);
}

[data-theme="light"] .payments-floating-field__input:hover {
  border-color: #C5D4E5;
}

[data-theme="light"] .payments-floating-field__input:focus {
  border-color: rgba(15, 159, 132, 0.28);
  box-shadow:
    0 0 0 4px rgba(15, 159, 132, 0.10),
    0 12px 26px rgba(15, 159, 132, 0.08);
}

[data-theme="light"] .payments-floating-field__control:focus-within .payments-floating-field__icon,
[data-theme="light"] .payments-floating-field--filled .payments-floating-field__icon,
[data-theme="light"] .payments-floating-field__control:focus-within .payments-floating-field__label,
[data-theme="light"] .payments-floating-field--filled .payments-floating-field__label,
[data-theme="light"] .payments-floating-field__input:not(:placeholder-shown) + .payments-floating-field__label {
  color: #0B6B58;
}

[data-theme="light"] .payments-floating-select__value--placeholder,
[data-theme="light"] .payments-floating-select__selected-hint,
[data-theme="light"] .payments-floating-select__option-hint {
  color: #6F8198;
}

[data-theme="light"] .payments-floating-select__selected-label,
[data-theme="light"] .payments-floating-select__option-label,
[data-theme="light"] .payments-floating-select__simple-label,
[data-theme="light"] .payments-floating-select__simple-value {
  color: #152235;
}

[data-theme="light"] .payments-floating-select__status {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #62748D;
}

[data-theme="light"] .payments-floating-select__status--success {
  border-color: rgba(15, 159, 132, 0.18);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.10), rgba(255,255,255,0.98));
  color: #0B6B58;
}

[data-theme="light"] .payments-floating-select__status--danger {
  border-color: rgba(220, 74, 88, 0.18);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.10), rgba(255,255,255,0.98));
  color: #C53A4C;
}

[data-theme="light"] .payments-floating-select__status--neutral {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #62748D;
}

[data-theme="light"] .payments-floating-select__chevron {
  border-color: #7C8EA5;
}

[data-theme="light"] .payments-floating-select--open .payments-floating-select__chevron {
  border-color: #0B6B58;
}

[data-theme="light"] .payments-floating-select__menu {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(242,247,253,0.96)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 26%);
  box-shadow:
    0 24px 48px rgba(19, 37, 71, 0.14),
    inset 0 1px 0 rgba(255,255,255,0.88);
}

[data-theme="light"] .payments-floating-select__option {
  background: rgba(255,255,255,0.84);
}

[data-theme="light"] .payments-floating-select__option:hover {
  border-color: rgba(15, 159, 132, 0.16);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.08), rgba(255,255,255,0.98));
}

[data-theme="light"] .payments-floating-select__option--active {
  border-color: rgba(59, 132, 232, 0.18);
  background: linear-gradient(135deg, rgba(59, 132, 232, 0.14), rgba(255,255,255,0.98));
  box-shadow: 0 12px 24px rgba(59, 132, 232, 0.10);
}

[data-theme="light"] .payments-floating-date__panel {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98), rgba(242,247,253,0.96)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 26%);
  box-shadow:
    0 24px 48px rgba(19, 37, 71, 0.14),
    inset 0 1px 0 rgba(255,255,255,0.88);
}

[data-theme="light"] .payments-floating-date__month {
  color: #152235;
}

[data-theme="light"] .payments-floating-date__nav {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .payments-floating-date__nav:hover {
  border-color: rgba(59, 132, 232, 0.18);
  background: linear-gradient(180deg, rgba(59, 132, 232, 0.10), rgba(255,255,255,0.98));
}

[data-theme="light"] .payments-floating-date__nav-icon {
  border-color: #71839A;
}

[data-theme="light"] .payments-floating-date__weekday {
  color: #6B7D95;
}

[data-theme="light"] .payments-floating-date__day {
  background: rgba(255,255,255,0.82);
  color: #152235;
}

[data-theme="light"] .payments-floating-date__day:hover {
  border-color: rgba(59, 132, 232, 0.16);
  background: linear-gradient(180deg, rgba(59, 132, 232, 0.10), rgba(255,255,255,0.98));
}

[data-theme="light"] .payments-floating-date__day--muted {
  color: #9AA8BC;
}

[data-theme="light"] .payments-floating-date__day--today {
  border-color: rgba(15, 159, 132, 0.16);
  color: #0B6B58;
}

[data-theme="light"] .payments-floating-date__day--selected {
  border-color: rgba(59, 132, 232, 0.20);
  background: linear-gradient(135deg, rgba(59, 132, 232, 0.18), rgba(41, 86, 168, 0.12));
  color: #18304D;
}

[data-theme="light"] .payments-form__intro-copy,
[data-theme="light"] .payments-form__member-card-copy,
[data-theme="light"] .payments-floating-field__hint {
  color: #5D7088;
}

[data-theme="light"] .payments-form__member-card--due {
  border-color: rgba(220, 74, 88, 0.18);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.06), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .payments-form__member-card--ok {
  border-color: rgba(15, 159, 132, 0.18);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.06), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .payments-form__member-card-change {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #5A6D86;
}

[data-theme="light"] .payments-form__action--secondary {
  color: #52647C;
}

[data-theme="light"] .payments-tabs {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .payments-tab--active {
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
  border-color: rgba(15, 159, 132, 0.18);
  color: #0B6B58;
  box-shadow: 0 10px 20px rgba(15, 159, 132, 0.10);
}

[data-theme="light"] .payments-panel__header {
  border-bottom-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 253, 0.95)),
    radial-gradient(circle at top left, rgba(15, 159, 132, 0.05), transparent 24%);
}

[data-theme="light"] .payment-entry {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.96)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.06), transparent 28%);
  box-shadow:
    0 14px 28px rgba(19, 37, 71, 0.06),
    inset 0 1px 0 rgba(255,255,255,0.86);
}

[data-theme="light"] .payment-entry:hover {
  box-shadow:
    0 18px 32px rgba(19, 37, 71, 0.09),
    inset 0 1px 0 rgba(255,255,255,0.88);
}

[data-theme="light"] .payment-entry__amount {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .payment-entry__reverse {
  border-color: rgba(220, 74, 88, 0.22);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.10), rgba(255, 255, 255, 0.98));
  color: #C53A4C;
}

@media (max-width: 980px) {
  .payments-hero,
  .payments-overview {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .payments-page {
    gap: 18px;
  }

  .payments-hero {
    padding: 20px;
    border-radius: 24px;
  }

  .payments-overview {
    grid-template-columns: 1fr;
  }

  .payments-form__split,
  .payments-form__actions {
    grid-template-columns: 1fr;
  }

  .payments-floating-date__panel {
    left: 0;
    right: auto;
    width: min(286px, calc(100vw - 56px));
  }

  .payment-entry {
    grid-template-columns: 1fr;
    align-items: flex-start;
  }

  .payment-entry__topline {
    flex-direction: column;
    align-items: flex-start;
  }

  .payment-entry__chip {
    align-self: flex-start;
  }

  .payment-entry__right {
    width: 100%;
    justify-content: space-between;
  }
}

[data-theme="light"] .balances-hero {
  border-color: color-mix(in srgb, var(--accent) 18%, #C8D7E7);
  background:
    radial-gradient(circle at 0% 0%, rgba(18, 168, 138, 0.18), transparent 36%),
    radial-gradient(circle at 100% 100%, rgba(59, 132, 232, 0.16), transparent 34%),
    linear-gradient(135deg, #FFFFFF 0%, #F7FBFF 54%, #EEF6FF 100%);
  box-shadow:
    0 22px 50px rgba(17, 33, 68, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .balances-hero__eyebrow {
  border-color: rgba(15, 159, 132, 0.26);
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.16), rgba(255, 255, 255, 0.92));
  color: #0B6B58;
}

[data-theme="light"] .balances-hero__title,
[data-theme="light"] .balances-section__title {
  color: #12233A;
}

[data-theme="light"] .balances-chip {
  border-color: #D3DDEA;
  background: rgba(255, 255, 255, 0.90);
  color: #576980;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78);
}

[data-theme="light"] .balances-chip--positive {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.16), rgba(255, 255, 255, 0.98));
  color: #0B6B58;
}

[data-theme="light"] .balances-chip--danger {
  border-color: rgba(220, 74, 88, 0.24);
  background: linear-gradient(135deg, rgba(220, 74, 88, 0.14), rgba(255, 255, 255, 0.98));
  color: #C53A4C;
}

[data-theme="light"] .balances-chip--info {
  border-color: rgba(47, 118, 222, 0.24);
  background: linear-gradient(135deg, rgba(47, 118, 222, 0.14), rgba(255, 255, 255, 0.98));
  color: #245FC1;
}

[data-theme="light"] .balances-hero__summary,
[data-theme="light"] .balances-hero__spotlight,
[data-theme="light"] .balances-stat,
[data-theme="light"] .balances-section,
[data-theme="light"] .balances-focus,
[data-theme="light"] .balance-member-card,
[data-theme="light"] .balances-settlement-item {
  border-color: #D3DDEA;
  box-shadow:
    0 16px 38px rgba(19, 37, 71, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.86);
}

[data-theme="light"] .balances-hero__summary,
[data-theme="light"] .balances-hero__spotlight,
[data-theme="light"] .balances-section,
[data-theme="light"] .balances-focus,
[data-theme="light"] .balance-member-card,
[data-theme="light"] .balances-settlement-item {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(244, 248, 253, 0.97)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.06), transparent 28%);
}

[data-theme="light"] .balances-stat {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F9FD 100%);
}

[data-theme="light"] .balances-stat--positive {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-stat--danger {
  border-color: rgba(220, 74, 88, 0.24);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-stat--warning {
  border-color: rgba(199, 106, 7, 0.26);
  background: linear-gradient(180deg, rgba(199, 106, 7, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-stat--info {
  border-color: rgba(47, 118, 222, 0.24);
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-stat__label,
[data-theme="light"] .balances-hero__summary-label,
[data-theme="light"] .balances-focus__label,
[data-theme="light"] .balance-member-card__amount-label,
