[data-theme="light"] .balances-settlement-party {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(244, 248, 252, 0.95));
}

[data-theme="light"] .balances-settlement-party--from {
  border-color: rgba(220, 74, 88, 0.18);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.10), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-settlement-party--to {
  border-color: rgba(15, 159, 132, 0.18);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.10), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .balances-settlement-party__label {
  color: #6B7D95;
}

[data-theme="light"] .balances-settlement-party--from .balances-settlement-party__name {
  color: #C53A4C;
}

[data-theme="light"] .balances-settlement-party--to .balances-settlement-party__name {
  color: #0B6B58;
}

[data-theme="light"] .balances-settlement-item__arrow {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #6E8097;
}

[data-theme="light"] .balances-settlement-item__line {
  background: #D3DDEA;
}

[data-theme="light"] .balances-settlement-item__amount {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #18304D;
}

[data-theme="light"] .balances-settled-empty {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.14), rgba(255, 255, 255, 0.98));
}

@media (max-width: 900px) {
  .balances-hero,
  .balances-section,
  .balances-focus {
    padding: 20px;
    border-radius: 24px;
  }

  .balances-focus {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .balances-page {
    gap: 18px;
  }

  .balances-stats-grid,
  .balances-members-grid,
  .balance-member-card__meta,
  .balance-member-card__back-grid {
    grid-template-columns: 1fr;
  }

  .balances-hero__summary,
  .balances-hero__spotlight {
    min-width: 100%;
  }

  .balance-member-card__header,
  .balances-settlement-item {
    flex-direction: column;
    align-items: flex-start;
  }

  .balance-member-card {
    min-height: auto;
    perspective: none;
  }

  .balance-member-card__inner {
    min-height: auto;
    transform: none !important;
  }

  .balance-member-card__face {
    position: relative;
    inset: auto;
    padding: 18px;
    backface-visibility: visible;
    -webkit-backface-visibility: visible;
  }

  .balance-member-card__face--back {
    display: none;
  }

  .balance-member-card__email {
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow-wrap: anywhere;
  }

  .balances-settlement-item__amount {
    margin-left: 0;
  }
}

@media (max-width: 640px) {
  .balances-settlement-item {
    grid-template-columns: 1fr;
    align-items: flex-start;
  }

  .balances-settlement-item__parties {
    grid-template-columns: 1fr;
  }

  .balances-settlement-item__connector {
    min-width: 0;
    justify-content: flex-start;
  }

  .balances-settlement-item__amount {
    justify-self: flex-start;
  }
}

[data-theme="light"] .members-page {
  gap: 24px;
}

[data-theme="light"] .members-hero {
  border-color: color-mix(in srgb, var(--accent) 18%, #C8D7E7);
  background:
    radial-gradient(circle at 0% 0%, rgba(18, 168, 138, 0.18), transparent 36%),
    radial-gradient(circle at 100% 100%, rgba(59, 132, 232, 0.16), transparent 34%),
    linear-gradient(135deg, #FFFFFF 0%, #F7FBFF 54%, #EEF6FF 100%);
  box-shadow:
    0 22px 50px rgba(17, 33, 68, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .members-hero__bg {
  filter: blur(18px);
  opacity: 0.95;
}

[data-theme="light"] .members-hero__bg--left {
  background: rgba(18, 168, 138, 0.22);
}

[data-theme="light"] .members-hero__bg--right {
  background: rgba(59, 132, 232, 0.18);
}

[data-theme="light"] .members-hero__eyebrow {
  border-color: rgba(15, 159, 132, 0.26);
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.16), rgba(255, 255, 255, 0.92));
  color: #0B6B58;
}

[data-theme="light"] .members-hero__title,
[data-theme="light"] .members-section-title {
  color: #12233A;
}

[data-theme="light"] .members-hero__subtitle,
[data-theme="light"] .members-section-copy {
  color: #41536C;
}

[data-theme="light"] .members-chip {
  border-color: #D3DDEA;
  background: rgba(255, 255, 255, 0.90);
  color: #576980;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78);
}

[data-theme="light"] .members-chip--accent {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(135deg, rgba(15, 159, 132, 0.16), rgba(255, 255, 255, 0.98));
  color: #0B6B58;
}

[data-theme="light"] .members-btn--primary {
  box-shadow: 0 16px 34px rgba(15, 159, 132, 0.22);
}

[data-theme="light"] .members-btn--primary:hover {
  box-shadow: 0 20px 38px rgba(15, 159, 132, 0.28);
}

[data-theme="light"] .members-btn--secondary {
  background: linear-gradient(180deg, #FFFFFF, #F5F8FD);
  color: #18304D;
  border-color: #D3DDEA;
  box-shadow: 0 12px 24px rgba(34, 55, 92, 0.08);
}

[data-theme="light"] .members-btn--secondary:hover {
  border-color: rgba(47, 118, 222, 0.26);
  background: linear-gradient(180deg, #FFFFFF, #EEF5FF);
  color: #17488E;
}

[data-theme="light"] .members-btn--danger {
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.12), rgba(255, 255, 255, 0.96));
  color: #C53A4C;
  border-color: rgba(220, 74, 88, 0.24);
  box-shadow: 0 12px 24px rgba(220, 74, 88, 0.12);
}

[data-theme="light"] .members-btn--danger:hover {
  box-shadow: 0 16px 30px rgba(220, 74, 88, 0.18);
}

[data-theme="light"] .members-stat,
[data-theme="light"] .members-directory,
[data-theme="light"] .members-empty {
  border-color: #D3DDEA;
  box-shadow:
    0 16px 38px rgba(19, 37, 71, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.86);
}

[data-theme="light"] .members-stat {
  background: linear-gradient(180deg, #FFFFFF 0%, #F6F9FD 100%);
}

[data-theme="light"] .members-stat--positive {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .members-stat--danger {
  border-color: rgba(220, 74, 88, 0.24);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .members-stat--warning {
  border-color: rgba(199, 106, 7, 0.26);
  background: linear-gradient(180deg, rgba(199, 106, 7, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .members-stat--info {
  border-color: rgba(47, 118, 222, 0.24);
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .members-stat__label,
[data-theme="light"] .member-card__balance-label,
[data-theme="light"] .member-card__meta-label {
  color: #62748D;
}

[data-theme="light"] .members-stat__hint,
[data-theme="light"] .members-directory__hint {
  color: #50627A;
}

[data-theme="light"] .members-directory {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.98)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 28%);
}

[data-theme="light"] .members-directory__hint {
  background: linear-gradient(180deg, #FFFFFF, #F6F9FD);
  border-color: #D3DDEA;
}

[data-theme="light"] .member-card {
  border-color: color-mix(in srgb, var(--member-accent) 26%, #CFDBE8);
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--member-accent) 18%, transparent), transparent 38%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(243, 248, 253, 0.96));
  box-shadow:
    0 20px 44px rgba(19, 37, 71, 0.10),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .member-card::before {
  background: linear-gradient(180deg, color-mix(in srgb, var(--member-accent) 10%, rgba(255,255,255,0.85)), transparent 44%);
}

[data-theme="light"] .member-card:hover,
[data-theme="light"] .member-card:focus-within {
  box-shadow: 0 28px 58px color-mix(in srgb, var(--member-accent) 18%, rgba(19, 37, 71, 0.12));
}

[data-theme="light"] .member-card__email {
  color: #667890;
  opacity: 1;
}

[data-theme="light"] .member-tag--self {
  color: #A45505;
  border-color: rgba(199, 106, 7, 0.26);
}

[data-theme="light"] .member-card__balance {
  border-color: color-mix(in srgb, var(--member-accent) 20%, #D4DEEA);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 250, 253, 0.94)),
    linear-gradient(135deg, color-mix(in srgb, var(--member-accent) 7%, transparent), transparent 60%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .member-card__balance--positive {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.16), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .member-card__balance--negative {
  border-color: rgba(220, 74, 88, 0.24);
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .member-card__balance--neutral {
  border-color: rgba(47, 118, 222, 0.22);
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .member-card__meta-item,
[data-theme="light"] .member-card__actions {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(244, 248, 252, 0.95));
}

[data-theme="light"] .member-action-btn--secondary {
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.12), rgba(255, 255, 255, 0.98));
  border-color: rgba(47, 118, 222, 0.24);
  color: #245FC1;
  box-shadow: 0 12px 24px rgba(47, 118, 222, 0.12);
}

[data-theme="light"] .member-action-btn--secondary:hover {
  box-shadow: 0 18px 30px rgba(47, 118, 222, 0.18);
}

[data-theme="light"] .member-action-btn--danger {
  background: linear-gradient(180deg, rgba(220, 74, 88, 0.12), rgba(255, 255, 255, 0.98));
  border-color: rgba(220, 74, 88, 0.24);
  color: #C53A4C;
  box-shadow: 0 12px 24px rgba(220, 74, 88, 0.12);
}

[data-theme="light"] .member-action-btn--danger:hover {
  box-shadow: 0 18px 30px rgba(220, 74, 88, 0.18);
}

@media (max-width: 900px) {
  .members-hero,
  .members-directory {
    padding: 20px;
    border-radius: 24px;
  }

  .member-card {
    min-height: 234px;
  }
}

@media (max-width: 640px) {
  .members-page {
    gap: 18px;
  }

  .members-stats-grid,
  .members-grid {
    grid-template-columns: 1fr;
  }

  .members-hero__actions {
    width: 100%;
    justify-content: stretch;
  }

  .members-hero__actions > * {
    flex: 1 1 100%;
  }

  .members-btn,
  .member-action-btn {
    width: 100%;
  }

  .member-card__meta {
    grid-template-columns: 1fr;
  }

  .member-card__tag-rail {
    max-width: none;
  }

  .member-card__email {
    white-space: normal;
    max-height: 36px;
    min-height: 36px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow-wrap: anywhere;
  }

  .member-card__actions {
    position: static;
    margin-top: 14px;
    transform: none;
    opacity: 1;
    pointer-events: auto;
  }
}

.expenses-page--clean {
  display: grid;
  gap: 20px;
}

.expenses-page--clean > * {
  animation: expensesFadeUp 0.42s ease both;
}

.expenses-page--clean > *:nth-child(2) {
  animation-delay: 0.04s;
}

.expenses-page--clean > *:nth-child(3) {
  animation-delay: 0.08s;
}

.expenses-page--clean > *:nth-child(4) {
  animation-delay: 0.12s;
}

.expenses-page--clean h1,
.expenses-page--clean h2,
.expenses-page--clean h3,
.expenses-modal-clean .app-modal__title {
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
}

.expenses-header,
.expenses-controls,
.expenses-ledger,
.expenses-empty--clean,
.expenses-empty-state--simple,
.expenses-modal-clean {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(75, 90, 126, 0.2);
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(13, 18, 30, 0.98), rgba(15, 21, 35, 0.98)),
    radial-gradient(circle at top right, rgba(45, 122, 236, 0.08), transparent 30%);
  box-shadow:
    0 18px 40px rgba(2, 8, 20, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.expenses-header::before,
.expenses-controls::before,
.expenses-ledger::before,
.expenses-modal-clean::before {
  content: "";
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, rgba(72, 225, 184, 0.34), rgba(93, 138, 255, 0.22), transparent 80%);
  pointer-events: none;
}

.expenses-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
  padding: 24px 26px;
  background:
    radial-gradient(circle at top left, rgba(37, 199, 159, 0.12), transparent 30%),
    radial-gradient(circle at bottom right, rgba(52, 113, 242, 0.12), transparent 32%),
    linear-gradient(145deg, rgba(10, 17, 33, 0.98), rgba(13, 20, 37, 0.98));
}

.expenses-header__main {
  display: grid;
  gap: 18px;
  flex: 1;
}

.expenses-header__eyebrow-row {
  display: flex;
  align-items: center;
}

.expenses-header__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border: 1px solid rgba(51, 208, 168, 0.2);
  border-radius: 999px;
  background: rgba(10, 28, 33, 0.68);
  color: #86E7CB;
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.expenses-header__title {
  margin: 0;
  color: #F6FAFF;
  font-size: 2.2rem;
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1;
  text-shadow: 0 4px 18px rgba(10, 18, 35, 0.18);
}

.expenses-header__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.expenses-mini-stat {
  position: relative;
  display: grid;
  gap: 8px;
  min-height: 92px;
  padding: 16px 18px;
  border: 1px solid rgba(76, 91, 126, 0.18);
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(16, 22, 37, 0.96), rgba(12, 17, 29, 0.96)),
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.03), transparent 34%);
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}

.expenses-mini-stat::after {
  content: "";
  position: absolute;
  inset: auto 18px 0 18px;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(49, 204, 163, 0.72), rgba(74, 129, 255, 0));
  opacity: 0.55;
}

.expenses-mini-stat--teal {
  border-color: rgba(43, 195, 156, 0.24);
  background:
    radial-gradient(circle at top left, rgba(43, 195, 156, 0.14), transparent 34%),
    linear-gradient(180deg, rgba(16, 22, 37, 0.96), rgba(12, 17, 29, 0.96));
}

.expenses-mini-stat--teal::after {
  background: linear-gradient(90deg, rgba(43, 195, 156, 0.92), rgba(43, 195, 156, 0.06));
}

.expenses-mini-stat--blue {
  border-color: rgba(74, 129, 255, 0.24);
  background:
    radial-gradient(circle at top left, rgba(74, 129, 255, 0.14), transparent 34%),
    linear-gradient(180deg, rgba(16, 22, 37, 0.96), rgba(12, 17, 29, 0.96));
}

.expenses-mini-stat--blue::after {
  background: linear-gradient(90deg, rgba(74, 129, 255, 0.9), rgba(74, 129, 255, 0.06));
}

.expenses-mini-stat--gold {
  border-color: rgba(233, 174, 74, 0.22);
  background:
    radial-gradient(circle at top left, rgba(233, 174, 74, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(16, 22, 37, 0.96), rgba(12, 17, 29, 0.96));
}

.expenses-mini-stat--gold::after {
  background: linear-gradient(90deg, rgba(233, 174, 74, 0.86), rgba(233, 174, 74, 0.06));
}

.expenses-mini-stat:hover {
  transform: translateY(-2px);
  border-color: rgba(90, 108, 150, 0.28);
  box-shadow: 0 16px 28px rgba(3, 10, 22, 0.18);
}

.expenses-mini-stat__label,
.expenses-row__meta,
.expenses-editor__label {
  color: #97A7C0;
  font-size: 0.78rem;
  font-weight: 700;
}

.expenses-mini-stat__value {
  color: #F4F7FD;
  font-size: 1.2rem;
  font-weight: 800;
  line-height: 1.2;
}

.expenses-header__action,
.expenses-empty__action,
.expenses-empty-state__action,
.expenses-editor__button--primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0 20px;
  border: none;
  border-radius: 16px;
  background: linear-gradient(135deg, #19C395 0%, #2E78F0 100%);
  color: #06131A;
  font-weight: 800;
  cursor: pointer;
  text-decoration: none;
  box-shadow: 0 16px 30px rgba(31, 104, 232, 0.22);
  transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
}

.expenses-header__action:hover,
.expenses-empty__action:hover,
.expenses-empty-state__action:hover,
.expenses-editor__button--primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 20px 34px rgba(31, 104, 232, 0.28);
  filter: saturate(1.04);
}

.expenses-controls {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 220px auto;
  gap: 12px;
  padding: 16px;
  align-items: center;
  background:
    linear-gradient(180deg, rgba(14, 20, 34, 0.98), rgba(12, 18, 31, 0.98)),
    radial-gradient(circle at top left, rgba(39, 192, 155, 0.06), transparent 25%);
}

.expenses-controls__search,
.expenses-controls__select,
.expenses-editor__input {
  width: 100%;
  min-height: 50px;
  padding: 0 16px;
  border: 1px solid rgba(82, 97, 136, 0.22);
  border-radius: 16px;
  background: rgba(17, 24, 40, 0.94);
  color: #F1F5FD;
  font-size: 0.96rem;
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  transition: border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
}

.expenses-controls__search:focus,
.expenses-controls__select:focus,
.expenses-editor__input:focus {
  outline: none;
  border-color: rgba(55, 207, 169, 0.34);
  box-shadow: 0 0 0 3px rgba(46, 204, 154, 0.1);
  background: rgba(17, 24, 39, 0.96);
}

.expenses-controls__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50px;
  padding: 0 18px;
  border: 1px solid rgba(76, 91, 127, 0.18);
  border-radius: 16px;
  color: #B6C4DA;
  font-weight: 700;
  white-space: nowrap;
  transition: transform 0.22s ease, border-color 0.22s ease, color 0.22s ease;
}

.expenses-controls__count:hover {
  transform: translateY(-1px);
  border-color: rgba(82, 98, 138, 0.26);
  color: #E2EAF8;
}

.expenses-filter-select {
  position: relative;
  width: 100%;
}

.expenses-filter-select__trigger {
  width: 100%;
  min-height: 50px;
  padding: 0 16px;
  border: 1px solid rgba(82, 97, 136, 0.22);
  border-radius: 16px;
  background: rgba(17, 24, 40, 0.94);
  color: #F1F5FD;
  font-size: 0.96rem;
  font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  cursor: pointer;
  transition: border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
}

.expenses-filter-select__trigger:hover,
.expenses-filter-select--open .expenses-filter-select__trigger {
  border-color: rgba(55, 207, 169, 0.34);
  box-shadow: 0 0 0 3px rgba(46, 204, 154, 0.1);
  background: rgba(17, 24, 39, 0.96);
}

.expenses-filter-select__value {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: left;
}

.expenses-filter-select__chevron {
  width: 10px;
  height: 10px;
  border-right: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  transform: rotate(45deg) translateY(-2px);
  opacity: 0.7;
  flex-shrink: 0;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.expenses-filter-select__chevron--open {
  transform: rotate(-135deg) translateY(-1px);
  opacity: 1;
}

.expenses-filter-select__menu {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  right: 0;
  z-index: 20;
  padding: 8px;
  border-radius: 18px;
  border: 1px solid rgba(82, 97, 136, 0.2);
  background:
    linear-gradient(180deg, rgba(17, 24, 39, 0.98), rgba(13, 19, 32, 0.98)),
    radial-gradient(circle at top left, rgba(39, 192, 155, 0.08), transparent 30%);
  box-shadow: 0 22px 40px rgba(4, 10, 22, 0.28);
  display: grid;
  gap: 4px;
}

.expenses-filter-select__option {
  width: 100%;
  min-height: 42px;
  padding: 0 14px;
  border: none;
  border-radius: 12px;
  background: transparent;
  color: #DDE6F6;
  font-size: 0.94rem;
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease;
}

.expenses-filter-select__option:hover,
.expenses-filter-select__option--active {
  background: rgba(70, 130, 230, 0.18);
  color: #F7FAFF;
}

.expenses-ledger {
  padding: 12px;
  background:
    linear-gradient(180deg, rgba(13, 19, 33, 0.98), rgba(11, 17, 29, 0.98)),
    radial-gradient(circle at top right, rgba(52, 113, 242, 0.06), transparent 24%);
  overflow: visible;
}

.expenses-ledger__list {
  display: grid;
  gap: 12px;
  overflow: visible;
}

.expenses-row {
  position: relative;
  z-index: 0;
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) auto;
  gap: 18px;
  align-items: center;
  padding: 14px 16px;
  border: 1px solid color-mix(in srgb, var(--expense-accent) 18%, rgba(79, 95, 132, 0.16));
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(18, 24, 39, 0.98), rgba(13, 18, 31, 0.98)),
    radial-gradient(circle at top left, color-mix(in srgb, var(--expense-accent) 10%, transparent), transparent 28%);
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.expenses-row::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16px;
  bottom: 16px;
  width: 3px;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--expense-accent), color-mix(in srgb, var(--expense-accent) 16%, transparent));
  opacity: 0.9;
}

.expenses-row:hover {
  z-index: 5;
  transform: translateY(-1px);
  box-shadow: 0 18px 32px rgba(3, 10, 22, 0.22);
  border-color: color-mix(in srgb, var(--expense-accent) 28%, rgba(95, 110, 148, 0.2));
}

.expenses-row__left,
.expenses-row__right,
.expenses-row__topline,
.expenses-row__actions,
.expenses-row__people,
.expenses-editor__split-top,
.expenses-editor__actions {
  display: flex;
  align-items: center;
}

.expenses-row__left {
  gap: 14px;
  min-width: 0;
}

.expenses-row__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--expense-accent);
  box-shadow: 0 0 0 8px color-mix(in srgb, var(--expense-accent) 12%, transparent);
}

.expenses-row__content {
  display: grid;
  gap: 10px;
  min-width: 0;
}

.expenses-row__topline {
  gap: 10px;
  flex-wrap: wrap;
}

.expenses-row__title {
  margin: 0;
  color: #F5F8FF;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.expenses-row__category {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30px;
  padding: 0 10px;
  border: 1px solid color-mix(in srgb, var(--expense-accent) 28%, rgba(82, 97, 136, 0.2));
  border-radius: 999px;
  background: color-mix(in srgb, var(--expense-accent) 14%, rgba(16, 22, 36, 0.92));
  color: color-mix(in srgb, var(--expense-accent) 72%, #F2F6FD);
  font-size: 0.78rem;
  font-weight: 700;
}

.expenses-row__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.expenses-row__meta span {
  position: relative;
}

.expenses-row__meta span:not(:last-child)::after {
  content: "";
  display: inline-block;
  width: 4px;
  height: 4px;
  margin-left: 10px;
  border-radius: 50%;
  background: rgba(133, 148, 179, 0.6);
  vertical-align: middle;
}

.expenses-row__note {
  margin: 0;
  color: #B9C7DA;
  font-size: 0.92rem;
  line-height: 1.55;
}

.expenses-row__right {
  gap: 12px;
}

.expenses-row__people {
  position: relative;
  justify-content: flex-end;
  padding: 2px 6px;
  border: 1px solid rgba(82, 97, 136, 0.14);
  border-radius: 999px;
  background: rgba(18, 25, 41, 0.54);
  cursor: default;
  transition: border-color 0.22s ease, background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
}

.expenses-row__people:hover {
  transform: translateY(-1px);
  border-color: color-mix(in srgb, var(--expense-accent) 26%, rgba(92, 107, 145, 0.2));
  background: color-mix(in srgb, var(--expense-accent) 8%, rgba(18, 25, 41, 0.84));
  box-shadow: 0 10px 18px rgba(4, 11, 24, 0.18);
}

.expenses-row__avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30px;
  height: 30px;
  margin-left: -8px;
  border: 2px solid rgba(12, 18, 31, 0.98);
  border-radius: 50%;
  background: rgba(21, 34, 56, 0.94);
  color: #E1EAF7;
  font-size: 0.72rem;
  font-weight: 800;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.expenses-row__avatar:first-child {
  margin-left: 0;
}

.expenses-row:hover .expenses-row__avatar {
  transform: translateY(-1px);
  box-shadow: 0 8px 16px rgba(5, 12, 26, 0.16);
}

.expenses-row__avatar--more {
  color: #9FB1CD;
}

.expenses-row__people-popover {
  position: absolute;
  bottom: calc(100% + 12px);
  right: 0;
  z-index: 20;
  min-width: 220px;
  max-width: 280px;
  padding: 14px;
  border: 1px solid color-mix(in srgb, var(--expense-accent) 24%, rgba(82, 97, 136, 0.22));
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(17, 24, 40, 0.98), rgba(12, 18, 31, 0.98)),
    radial-gradient(circle at top left, color-mix(in srgb, var(--expense-accent) 10%, transparent), transparent 32%);
  box-shadow: 0 18px 36px rgba(2, 8, 20, 0.28);
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  pointer-events: none;
  transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s ease;
}

.expenses-row__people-popover::after {
  content: "";
  position: absolute;
  top: 100%;
  right: 20px;
  width: 10px;
  height: 10px;
  border-right: 1px solid color-mix(in srgb, var(--expense-accent) 24%, rgba(82, 97, 136, 0.22));
  border-bottom: 1px solid color-mix(in srgb, var(--expense-accent) 24%, rgba(82, 97, 136, 0.22));
  background: rgba(14, 21, 35, 0.98);
  transform: rotate(45deg) translateY(-5px);
}

.expenses-row__people:hover .expenses-row__people-popover {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.expenses-row__people-popover-title {
  display: block;
  margin-bottom: 10px;
  color: #F2F6FD;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.expenses-row__people-popover-list {
  display: grid;
  gap: 8px;
}

.expenses-row__people-name {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 36px;
  padding: 0 12px;
  border-radius: 12px;
  background:
    linear-gradient(180deg, rgba(24, 32, 52, 0.92), rgba(19, 27, 45, 0.92)),
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.04), transparent 60%);
  border: 1px solid rgba(82, 97, 136, 0.24);
  color: #E8F0FB;
  font-size: 0.82rem;
  font-weight: 700;
}

.expenses-row__people-percentage {
  color: #9FD7C7;
  font-weight: 800;
  font-size: 0.8rem;
  margin-left: 10px;
  white-space: nowrap;
}

.expenses-row__people-member {
  margin-right: auto;
  text-align: left;
  color: inherit;
}

.expenses-row__amount {
  min-width: 110px;
  color: #F7FBFF;
  font-size: 1.1rem;
  font-weight: 800;
  text-align: right;
  text-shadow: 0 6px 18px rgba(4, 12, 28, 0.22);
  letter-spacing: -0.02em;
}

.expenses-row__actions {
  gap: 8px;
}

.expenses-row__action,
.expenses-editor__button {
  min-height: 36px;
  padding: 0 12px;
  border-radius: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.expenses-row__action {
  border: 1px solid rgba(82, 97, 136, 0.22);
  background: rgba(16, 22, 36, 0.88);
  position: relative;
  overflow: hidden;
}

.expenses-row__action:hover,
.expenses-editor__button:hover {
  transform: translateY(-1px);
}

.expenses-row__action::before,
.expenses-editor__button::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 48%);
  opacity: 0;
  transition: opacity 0.22s ease;
}

.expenses-row__action:hover::before,
.expenses-editor__button:hover::before {
  opacity: 1;
}

.expenses-row__action--edit {
  color: #9AB8FF;
}

.expenses-row__action--delete {
  color: #FF8A9A;
}

.expenses-ledger__footer {
  padding: 14px 8px 4px;
}

.expenses-empty--clean,
.expenses-empty-state--simple {
  display: grid;
  justify-items: center;
  gap: 14px;
  padding: 40px 24px;
  text-align: center;
}

.expenses-empty__title,
.expenses-empty-state__title {
  margin: 0;
  color: #F4F7FD;
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.expenses-empty-state__copy {
  margin: 0;
  color: #9AAAC2;
}

.expenses-modal-clean .app-modal__header {
  padding-bottom: 10px;
}

.expenses-modal-clean {
  background:
    radial-gradient(circle at top left, rgba(38, 194, 155, 0.1), transparent 26%),
    radial-gradient(circle at bottom right, rgba(68, 123, 243, 0.1), transparent 24%),
    linear-gradient(180deg, #0d1117, rgba(11, 17, 29, 0.98));
  max-height: 90vh;
  overflow-y: auto;
}

.expenses-modal-clean .app-modal__header::after {
  content: "";
  display: block;
  width: 84px;
  height: 3px;
  margin-top: 12px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(35, 199, 157, 0.9), rgba(76, 127, 255, 0.18));
}

.expenses-modal-clean .app-modal__title {
  width: 100%;
}

.expenses-modal-clean .app-modal__close {
  background: rgba(17, 24, 39, 0.9);
}

.expenses-modal-clean .app-modal__close:hover {
  background: rgba(20, 31, 54, 0.96);
}

.expenses-modal-clean__title {
  color: #F4F7FD;
  font-size: 1.45rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.expenses-editor {
  display: grid;
  gap: 16px;
}

.expenses-editor__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.expenses-editor__field {
  display: grid;
  gap: 8px;
}

.expenses-editor__label {
  font-size: 0.82rem;
  letter-spacing: 0.02em;
}

.expenses-editor__required {
  color: #FF879A;
}

.expenses-editor__input--textarea {
  min-height: 112px;
  padding-top: 14px;
  resize: vertical;
}

.expenses-editor__input {
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
}

.expenses-editor__input:hover {
  border-color: rgba(92, 109, 151, 0.3);
}

.expenses-editor__split {
  position: relative;
  display: grid;
  gap: 14px;
  padding: 16px;
  border: 1px solid rgba(78, 94, 131, 0.18);
  border-radius: 20px;
  background:
    radial-gradient(circle at top right, rgba(38, 194, 155, 0.08), transparent 30%),
    rgba(16, 22, 35, 0.78);
}

.expenses-editor__split::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(49, 205, 164, 0.08), transparent 34%);
  pointer-events: none;
}

.expenses-editor__split-top {
  justify-content: space-between;
  gap: 12px;
}

.expenses-editor__split-title {
  margin: 0;
  color: #EFF4FC;
  font-size: 1rem;
  font-weight: 800;
}

.expenses-editor__split-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(26, 93, 79, 0.5);
  color: #84EBCF;
  font-size: 0.82rem;
  font-weight: 800;
}

.expenses-editor__members {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 10px;
}

.expenses-editor__member {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 10px;
  min-height: 54px;
  padding: 10px 12px;
  border: 1px solid rgba(82, 97, 136, 0.2);
  border-radius: 16px;
  background:
    linear-gradient(180deg, rgba(17, 23, 38, 0.92), rgba(14, 20, 34, 0.92)),
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.03), transparent 36%);
  color: #E7EFFC;
  cursor: pointer;
  transition: transform 0.22s ease, border-color 0.22s ease, background 0.22s ease;
  text-align: left;
}

.expenses-editor__member:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 20px rgba(3, 10, 22, 0.14);
}

.expenses-editor__member--selected {
  border-color: rgba(42, 205, 163, 0.28);
  background:
    radial-gradient(circle at top left, rgba(42, 205, 163, 0.14), transparent 34%),
    rgba(16, 35, 35, 0.96);
}

.expenses-editor__member-avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  background: rgba(24, 38, 62, 0.94);
  color: #DCE8FA;
  font-size: 0.74rem;
  font-weight: 800;
  flex-shrink: 0;
}

.expenses-editor__member-name {
  color: #F1F5FD;
  font-size: 0.92rem;
  font-weight: 700;
}

.expenses-editor__actions {
  justify-content: flex-end;
  gap: 10px;
}

.expenses-editor__button {
  border: 1px solid rgba(82, 97, 136, 0.22);
  background: rgba(16, 22, 36, 0.88);
  color: #E7EFFC;
  position: relative;
  overflow: hidden;
}

.expenses-editor__button--ghost {
  min-width: 132px;
}

.expenses-editor__button--primary {
  min-width: 170px;
}

.expenses-editor__button:disabled {
  opacity: 0.72;
  cursor: not-allowed;
}

[data-theme="light"] .expenses-header,
[data-theme="light"] .expenses-controls,
[data-theme="light"] .expenses-ledger,
[data-theme="light"] .expenses-empty--clean,
[data-theme="light"] .expenses-empty-state--simple,
[data-theme="light"] .expenses-modal-clean {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(246, 250, 254, 0.98)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 28%);
  box-shadow:
    0 18px 40px rgba(19, 37, 71, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .expenses-header {
  background:
    radial-gradient(circle at top left, rgba(15, 159, 132, 0.14), transparent 30%),
    radial-gradient(circle at bottom right, rgba(47, 118, 222, 0.12), transparent 32%),
    linear-gradient(135deg, #FFFFFF 0%, #F7FBFF 55%, #EEF5FF 100%);
}

[data-theme="light"] .expenses-header__eyebrow {
  border-color: rgba(15, 159, 132, 0.22);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
  color: #0B6B58;
}

[data-theme="light"] .expenses-header__title,
[data-theme="light"] .expenses-mini-stat__value,
[data-theme="light"] .expenses-row__title,
[data-theme="light"] .expenses-row__amount,
[data-theme="light"] .expenses-empty__title,
[data-theme="light"] .expenses-empty-state__title,
[data-theme="light"] .expenses-modal-clean__title,
[data-theme="light"] .expenses-editor__split-title {
  color: #14263F;
}

[data-theme="light"] .expenses-mini-stat,
[data-theme="light"] .expenses-controls__count,
[data-theme="light"] .expenses-row,
[data-theme="light"] .expenses-editor__split,
[data-theme="light"] .expenses-row__avatar,
[data-theme="light"] .expenses-row__action,
[data-theme="light"] .expenses-editor__button {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F5F8FD);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .expenses-mini-stat--teal {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-mini-stat--blue {
  border-color: rgba(47, 118, 222, 0.24);
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-mini-stat--gold {
  border-color: rgba(199, 106, 7, 0.24);
  background: linear-gradient(180deg, rgba(199, 106, 7, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-header::before,
[data-theme="light"] .expenses-controls::before,
[data-theme="light"] .expenses-ledger::before,
[data-theme="light"] .expenses-modal-clean::before {
  background: linear-gradient(90deg, rgba(15, 159, 132, 0.28), rgba(47, 118, 222, 0.2), transparent 80%);
}

[data-theme="light"] .expenses-mini-stat__label,
[data-theme="light"] .expenses-row__meta,
[data-theme="light"] .expenses-editor__label,
[data-theme="light"] .expenses-empty-state__copy,
[data-theme="light"] .expenses-controls__count {
  color: #62748D;
}

[data-theme="light"] .expenses-controls__search,
[data-theme="light"] .expenses-controls__select,
[data-theme="light"] .expenses-editor__input {
  border-color: #D3DDEA;
  background: #FFFFFF;
  color: #17304E;
}

[data-theme="light"] .expenses-filter-select__trigger {
  border-color: #D3DDEA;
  background: #FFFFFF;
  color: #17304E;
}

[data-theme="light"] .expenses-controls__search:focus,
[data-theme="light"] .expenses-controls__select:focus,
[data-theme="light"] .expenses-editor__input:focus {
  border-color: rgba(47, 118, 222, 0.28);
  box-shadow: 0 0 0 3px rgba(47, 118, 222, 0.1);
  background: #FFFFFF;
}

[data-theme="light"] .expenses-filter-select__trigger:hover,
[data-theme="light"] .expenses-filter-select--open .expenses-filter-select__trigger {
  border-color: rgba(47, 118, 222, 0.28);
  box-shadow: 0 0 0 3px rgba(47, 118, 222, 0.1);
  background: #FFFFFF;
}

[data-theme="light"] .expenses-filter-select__menu {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 248, 253, 0.98)),
    radial-gradient(circle at top left, rgba(47, 118, 222, 0.06), transparent 30%);
  box-shadow: 0 18px 30px rgba(19, 37, 71, 0.12);
}

[data-theme="light"] .expenses-filter-select__option {
  color: #35506E;
}

[data-theme="light"] .expenses-filter-select__option:hover,
[data-theme="light"] .expenses-filter-select__option--active {
  background: rgba(47, 118, 222, 0.12);
  color: #17304E;
}

[data-theme="light"] .expenses-row__note {
  color: #53657D;
}

[data-theme="light"] .expenses-mini-stat:hover,
[data-theme="light"] .expenses-row:hover {
  box-shadow: 0 18px 30px rgba(19, 37, 71, 0.1);
}

[data-theme="light"] .expenses-row__people {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .expenses-row__people:hover {
  border-color: color-mix(in srgb, var(--expense-accent) 24%, #D3DDEA);
  background: linear-gradient(180deg, #FFFFFF, #EEF5FF);
}

[data-theme="light"] .expenses-row__people-popover {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(245, 249, 253, 0.99)),
    radial-gradient(circle at top left, color-mix(in srgb, var(--expense-accent) 8%, transparent), transparent 32%);
  box-shadow: 0 18px 36px rgba(19, 37, 71, 0.12);
}

[data-theme="light"] .expenses-row__people-popover::after {
  border-right-color: #D3DDEA;
  border-bottom-color: #D3DDEA;
  background: #F7FAFE;
}

[data-theme="light"] .expenses-row__people-popover-title {
  color: #18304D;
}

[data-theme="light"] .expenses-row__people-name {
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  border-color: #D3DDEA;
  color: #18304D;
}

[data-theme="light"] .expenses-row__people-percentage {
  color: #0B6B58;
}

[data-theme="light"] .expenses-row__avatar {
  color: #55739A;
}

[data-theme="light"] .expenses-row__action--edit {
  color: #245FC1;
}

[data-theme="light"] .expenses-row__action--delete {
  color: #C53A4C;
}

[data-theme="light"] .expenses-editor__member {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .expenses-editor__member--selected {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-editor__member-avatar {
  background: linear-gradient(180deg, #F5F8FD, #EAF1FA);
  color: #55739A;
}

[data-theme="light"] .expenses-editor__member-name {
  color: #18304D;
}

[data-theme="light"] .expenses-editor__split-pill {
  background: rgba(15, 159, 132, 0.12);
  color: #0B6B58;
}

@keyframes expensesFadeUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 900px) {
  .expenses-header,
  .expenses-row {
    grid-template-columns: 1fr;
  }

  .expenses-header {
    flex-direction: column;
  }

  .expenses-header__stats,
  .expenses-controls,
  .expenses-editor__grid {
    grid-template-columns: 1fr;
  }

  .expenses-row__right,
  .expenses-editor__split-top {
    width: 100%;
    justify-content: space-between;
    flex-wrap: wrap;
  }
}

@media (max-width: 640px) {
  .expenses-page--clean {
    gap: 16px;
  }

  .expenses-header,
  .expenses-controls,
  .expenses-ledger,
  .expenses-empty--clean,
  .expenses-empty-state--simple,
  .expenses-modal-clean {
    border-radius: 20px;
  }

  .expenses-header,
  .expenses-controls,
  .expenses-empty--clean,
  .expenses-empty-state--simple {
    padding: 18px;
  }

  .expenses-row {
    padding: 16px 18px;
  }

  .expenses-header__title {
    font-size: 1.8rem;
  }

  .expenses-row__right,
  .expenses-editor__actions {
    flex-direction: column;
    align-items: stretch;
  }

  .expenses-row__amount {
    text-align: left;
  }

  .expenses-row__people-popover {
    bottom: calc(100% + 10px);
    left: 0;
    right: auto;
    max-width: min(280px, calc(100vw - 64px));
  }

  .expenses-row__people-popover::after {
    left: 20px;
    right: auto;
  }

  .expenses-row__action,
  .expenses-editor__button,
  .expenses-header__action,
  .expenses-empty__action,
  .expenses-empty-state__action {
    width: 100%;
  }
}

@media (max-width: 640px) {
  .app-modal__backdrop {
    padding: 12px;
    align-items: flex-start;
  }

  .app-modal {
    max-height: 92vh;
    padding: 20px;
    border-radius: 20px;
  }
}

.expenses-editor__split-copy {
  margin: 4px 0 0;
  color: #96A7C1;
  font-size: 0.88rem;
  line-height: 1.5;
}

.expenses-editor__member-picker {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  gap: 10px;
}

.expenses-editor__select {
  position: relative;
  z-index: 1;
}

.expenses-editor__select-trigger {
  width: 100%;
  min-height: 46px;
  padding: 0 14px;
  border: 1px solid rgba(82, 97, 136, 0.22);
  border-radius: 14px;
  background: rgba(16, 22, 36, 0.9);
  color: #E9F1FD;
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  transition: border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
}

.expenses-editor__select:hover .expenses-editor__select-trigger,
.expenses-editor__select--open .expenses-editor__select-trigger {
  border-color: rgba(49, 205, 164, 0.28);
  box-shadow: 0 0 0 3px rgba(46, 204, 154, 0.1);
}

.expenses-editor__select-icon {
  width: 30px;
  height: 30px;
  border-radius: 10px;
  background: rgba(21, 35, 56, 0.94);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #8CE6CF;
}

.expenses-editor__icon-svg {
  width: 18px;
  height: 18px;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.6;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.expenses-editor__select-value {
  flex: 1;
  text-align: left;
  font-weight: 700;
  font-size: 0.95rem;
}

.expenses-editor__select-value--placeholder {
  color: #8EA1BD;
  font-weight: 600;
}

.expenses-editor__select-chevron {
  width: 8px;
  height: 8px;
  border-right: 2px solid #90A6C2;
  border-bottom: 2px solid #90A6C2;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
  margin-left: 6px;
}

.expenses-editor__select-chevron--open {
  transform: rotate(-135deg);
}

.expenses-editor__select-menu {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  right: 0;
  z-index: 20;
  border: 1px solid rgba(82, 97, 136, 0.22);
  border-radius: 16px;
  background:
    linear-gradient(180deg, rgba(17, 24, 40, 0.98), rgba(12, 18, 31, 0.98)),
    radial-gradient(circle at top left, rgba(49, 205, 164, 0.08), transparent 30%);
  box-shadow: 0 16px 30px rgba(3, 10, 22, 0.24);
  max-height: 220px;
  overflow-y: auto;
  padding: 6px;
}

.expenses-editor__select-option {
  width: 100%;
  border: none;
  background: transparent;
  color: #E7EFFC;
  padding: 12px 12px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 10px;
  cursor: pointer;
  font-weight: 600;
  transition: background 0.2s ease, color 0.2s ease;
}

.expenses-editor__select-option:hover,
.expenses-editor__select-option--active {
  background: rgba(35, 45, 70, 0.6);
  color: #F4F7FD;
}

.expenses-editor__select-option-avatar {
  width: 36px;
  height: 36px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(21, 35, 56, 0.94);
  color: #E3EDFB;
  font-weight: 800;
  font-size: 0.78rem;
  flex-shrink: 0;
}

.expenses-editor__utility-button,
.expenses-editor__utility-link {
  min-height: 46px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid rgba(82, 97, 136, 0.22);
  background: rgba(16, 22, 36, 0.88);
  color: #E7EFFC;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.22s ease, border-color 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
}

.expenses-editor__utility-button:hover,
.expenses-editor__utility-link:hover {
  transform: translateY(-1px);
  border-color: rgba(99, 115, 156, 0.3);
  box-shadow: 0 14px 24px rgba(3, 10, 22, 0.14);
}

.expenses-editor__utility-button--soft,
.expenses-editor__utility-link {
  color: #98B8FF;
}

.expenses-editor__utility-button:disabled,
.expenses-editor__utility-link:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.expenses-editor__mode-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

.expenses-editor__mode-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px;
  border: 1px solid rgba(78, 94, 131, 0.18);
  border-radius: 16px;
  background: rgba(15, 21, 35, 0.76);
}

.expenses-editor__mode-button {
  min-height: 40px;
  padding: 0 14px;
  border: 1px solid transparent;
  border-radius: 12px;
  background: transparent;
  color: #A6B5CC;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
}

.expenses-editor__mode-button--active {
  border-color: rgba(49, 205, 164, 0.24);
  background: linear-gradient(135deg, rgba(49, 205, 164, 0.16), rgba(67, 121, 245, 0.16));
  color: #F4F8FF;
}

.expenses-editor__selected-list {
  display: grid;
  gap: 10px;
}

.expenses-editor__selected-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border: 1px solid rgba(82, 97, 136, 0.2);
  border-radius: 18px;
  background:
    linear-gradient(180deg, rgba(17, 23, 38, 0.92), rgba(13, 19, 34, 0.92)),
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.03), transparent 36%);
}

.expenses-editor__selected-main,
.expenses-editor__percentage-field,
.expenses-editor__summary-bar {
  display: flex;
  align-items: center;
}

.expenses-editor__selected-main {
  gap: 12px;
  min-width: 0;
}

.expenses-editor__selected-copy {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.expenses-editor__selected-share {
  color: #89EACD;
  font-size: 0.86rem;
  font-weight: 700;
}

.expenses-editor__selected-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(26, 93, 79, 0.42);
  color: #8FEAD1;
  font-size: 0.8rem;
  font-weight: 800;
}

.expenses-editor__percentage-field {
  gap: 8px;
}

.expenses-editor__percentage-input {
  width: 92px;
  min-height: 42px;
  padding: 0 12px;
  border: 1px solid rgba(82, 97, 136, 0.22);
  border-radius: 12px;
  background: rgba(19, 26, 42, 0.9);
  color: #F2F6FD;
  font-weight: 700;
  text-align: right;
}

.expenses-editor__percentage-input:focus {
  outline: none;
  border-color: rgba(49, 205, 164, 0.28);
  box-shadow: 0 0 0 3px rgba(46, 204, 154, 0.1);
}

.expenses-editor__percentage-symbol {
  color: #A6B5CC;
  font-size: 0.9rem;
  font-weight: 700;
}

.expenses-editor__remove-member {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(220, 74, 88, 0.2);
  border-radius: 12px;
  background: rgba(42, 18, 24, 0.72);
  color: #FF9CAA;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.22s ease, background 0.22s ease, border-color 0.22s ease;
}

.expenses-editor__remove-member:hover {
  transform: translateY(-1px);
  background: rgba(58, 22, 30, 0.86);
  border-color: rgba(220, 74, 88, 0.32);
}

.expenses-editor__summary-bar {
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  padding-top: 4px;
  color: #9CB0CA;
  font-size: 0.84rem;
  font-weight: 700;
}

.expenses-editor__warning {
  margin-top: 6px;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid rgba(220, 74, 88, 0.24);
  background: rgba(50, 20, 24, 0.6);
  color: #FF9BA9;
  font-size: 0.82rem;
  font-weight: 700;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.expenses-editor__warning--active {
  opacity: 1;
  transform: translateY(0);
}

.groups-page {
  display: grid;
  gap: 18px;
}

.groups-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 24px;
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.09);
  background:
    radial-gradient(circle at top left, rgba(29, 158, 117, 0.18), transparent 35%),
    radial-gradient(circle at bottom right, rgba(60, 130, 246, 0.18), transparent 40%),
    linear-gradient(145deg, rgba(12, 18, 30, 0.98), rgba(10, 15, 25, 0.98));
  box-shadow:
    0 20px 36px rgba(2, 8, 20, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.groups-hero__left {
  display: grid;
  gap: 8px;
}

.groups-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid rgba(29, 158, 117, 0.4);
  background: rgba(29, 158, 117, 0.18);
  color: #8FF2D3;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
  width: fit-content;
}

.groups-hero__title {
  margin: 0;
  color: #F6FAFF;
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.groups-hero__meta {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.groups-hero__pill {
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid rgba(29, 158, 117, 0.45);
  background: rgba(29, 158, 117, 0.18);
  color: #1D9E75;
  font-weight: 700;
  font-size: 0.78rem;
}

.groups-hero__pill--muted {
  border-color: rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: #9FB0C6;
}

.groups-hero__cta {
  padding: 10px 18px;
  border-radius: 14px;
  border: 1px solid rgba(29, 158, 117, 0.6);
  background: linear-gradient(135deg, rgba(29, 158, 117, 0.36), rgba(29, 158, 117, 0.18));
  color: #E6FFF5;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.groups-hero__cta:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 26px rgba(29, 158, 117, 0.28);
  border-color: rgba(29, 158, 117, 0.9);
}

.groups-search {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-radius: 18px;
  border: 1px solid rgba(255, 255, 255, 0.09);
  background: linear-gradient(135deg, rgba(13, 17, 23, 0.96), rgba(15, 22, 34, 0.9));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

.groups-search__icon {
  color: #6EE7C2;
  font-size: 1rem;
}

.groups-search__input {
  flex: 1;
  border: none;
  background: transparent;
  color: #F3F6FB;
  font-size: 0.95rem;
  outline: none;
}

.groups-search__input::placeholder {
  color: #97A4B7;
}

.groups-search__count {
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid rgba(29, 158, 117, 0.45);
  background: rgba(29, 158, 117, 0.18);
  color: #1D9E75;
  font-weight: 700;
  font-size: 0.8rem;
  white-space: nowrap;
}

.groups-tabs {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.groups-section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 6px 4px 0;
}

.groups-section-title {
  color: #F1F5FB;
  font-size: 1.1rem;
  font-weight: 800;
}

.groups-section-subtitle {
  color: #8F9BB0;
  font-size: 0.85rem;
  margin-top: 4px;
}

.groups-section-count {
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid rgba(29, 158, 117, 0.45);
  background: rgba(29, 158, 117, 0.18);
  color: #1D9E75;
  font-weight: 700;
  font-size: 0.8rem;
  white-space: nowrap;
}

.groups-tab {
  border-radius: 999px;
  padding: 8px 16px;
  border: 1px solid rgba(255, 255, 255, 0.09);
  background: rgba(255, 255, 255, 0.03);
  color: #8F9BB0;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.groups-tab--active {
  color: #0B1117;
  background: #1D9E75;
  border-color: rgba(29, 158, 117, 0.65);
  box-shadow: 0 10px 24px rgba(29, 158, 117, 0.25);
}

.groups-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.group-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.09);
  border-radius: 20px;
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  perspective: 1000px;
  min-height: 320px;
}

.group-card--error {
  min-height: 360px;
}

.group-card:hover {
  transform: translateY(-4px);
  border-color: rgba(29, 158, 117, 0.55);
  box-shadow: 0 18px 32px rgba(29, 158, 117, 0.2);
}

.group-card--active {
  border-color: rgba(29, 158, 117, 0.75);
  box-shadow: 0 0 0 1px rgba(29, 158, 117, 0.45), 0 18px 32px rgba(29, 158, 117, 0.2);
}

.group-card--discover {
  border-style: dashed;
}

.group-card__delete {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 34px;
  height: 34px;
  border-radius: 10px;
  border: 1px solid rgba(255, 88, 104, 0.45);
  background: rgba(255, 88, 104, 0.12);
  color: #FF9CA8;
  font-weight: 700;
  font-size: 0.9rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: translateY(-4px);
  transition: opacity 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
  z-index: 3;
}

.group-card:hover .group-card__delete {
  opacity: 1;
  transform: translateY(0);
}

.group-card--flip .group-card__delete {
  opacity: 0;
  pointer-events: none;
}

.group-card__front,
.group-card__back {
  backface-visibility: hidden;
  transition: transform 0.5s ease;
}

.group-card__front {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.group-card__back {
  position: absolute;
  inset: 0;
  padding: 16px;
  border-radius: 20px;
  background: rgba(14, 18, 26, 0.96);
  border: 1px solid rgba(255, 88, 104, 0.35);
  transform: rotateY(180deg);
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(120, 140, 170, 0.55) transparent;
}

.group-card__back::-webkit-scrollbar {
  width: 6px;
}

.group-card__back::-webkit-scrollbar-track {
  background: transparent;
  margin: 6px 0;
}

.group-card__back::-webkit-scrollbar-thumb {
  background: rgba(120, 140, 170, 0.55);
  border-radius: 999px;
  border: 2px solid transparent;
  background-clip: content-box;
}

.group-card__back-input {
  margin-top: 6px;
}

.group-card__back-check {
  margin-top: 8px;
}

.group-card__back--error {
  gap: 10px;
}

.group-card--flip .group-card__front {
  transform: rotateY(180deg);
}

.group-card--flip .group-card__back {
  transform: rotateY(0deg);
}

.group-card__back-title {
  font-size: 1.05rem;
  font-weight: 800;
  color: #FFD6DB;
}

.group-card__back-copy {
  color: #C6D0E2;
  font-size: 0.78rem;
  line-height: 1.35;
  margin-top: 4px;
}

.group-card__back-error {
  padding: 8px 10px;
  border-radius: 10px;
  border: 1px solid rgba(255, 88, 104, 0.45);
  background: rgba(255, 88, 104, 0.12);
  color: #FFB3BD;
  font-size: 0.78rem;
  font-weight: 700;
}

.group-card__back-check {
  display: grid;
  grid-template-columns: 18px 1fr;
  align-items: center;
  gap: 10px;
  color: #E9EEF7;
  font-size: 0.82rem;
}

.group-card__back-check input {
  accent-color: #FF5C6A;
}

.group-card__back-input {
  display: grid;
  gap: 6px;
  color: #9FB0C6;
  font-size: 0.78rem;
}

.group-card__back-input input {
  width: 100%;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: #F3F6FB;
}

.group-card__back-actions {
  margin-top: auto;
  display: flex;
  gap: 10px;
}

.group-card__back-actions .group-card__back-cancel,
.group-card__back-actions .group-card__back-confirm {
  min-height: 40px;
}

.group-card__back-cancel {
  flex: 1;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: transparent;
  color: #C6D0E2;
  font-weight: 700;
  cursor: pointer;
}

.group-card__back-confirm {
  flex: 1.2;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255, 88, 104, 0.5);
  background: rgba(255, 88, 104, 0.2);
  color: #FFD1D7;
  font-weight: 800;
  cursor: pointer;
}

.group-card__back-confirm:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.leave-confirm {
  display: grid;
  gap: 12px;
}

.leave-confirm__text {
  color: #C6D0E2;
  font-size: 0.88rem;
  line-height: 1.5;
}

.leave-confirm__error {
  padding: 8px 10px;
  border-radius: 10px;
  border: 1px solid rgba(255, 88, 104, 0.45);
  background: rgba(255, 88, 104, 0.12);
  color: #FFB3BD;
  font-size: 0.8rem;
  font-weight: 700;
}

.leave-confirm__input {
  display: grid;
  gap: 6px;
  color: #9FB0C6;
  font-size: 0.78rem;
}

.leave-confirm__input input {
  width: 100%;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  color: #F3F6FB;
}

.leave-confirm__check {
  display: grid;
  grid-template-columns: 18px 1fr;
  align-items: center;
  gap: 10px;
  color: #E9EEF7;
  font-size: 0.82rem;
}

.leave-confirm__actions {
  display: flex;
  gap: 10px;
}

.leave-confirm__cancel {
  flex: 1;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: transparent;
  color: #C6D0E2;
  font-weight: 700;
  cursor: pointer;
}

.leave-confirm__confirm {
  flex: 1.2;
  padding: 10px;
  border-radius: 12px;
  border: 1px solid rgba(255, 88, 104, 0.5);
  background: rgba(255, 88, 104, 0.2);
  color: #FFD1D7;
  font-weight: 800;
  cursor: pointer;
}

.leave-confirm__confirm:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.group-card__icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 1.1rem;
}

.group-card__title {
  color: #F5F8FF;
  font-size: 1.1rem;
  font-weight: 800;
}

.group-card__org {
  color: #9CA8BA;
  font-size: 0.82rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.group-card__location {
  display: flex;
  align-items: center;
  gap: 6px;
  color: #A7B3C6;
  font-size: 0.86rem;
}

.group-card__pin {
  font-size: 0.9rem;
}

.group-card__divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.08);
  margin: 6px 0;
}

.group-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.group-card__members {
  display: flex;
  align-items: center;
  gap: 0;
}

.group-card__avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid #0d1117;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  margin-left: -6px;
}

.group-card__avatar:first-child {
  margin-left: 0;
}

.group-card__members-count {
  margin-left: 8px;
  color: #8FA0B8;
  font-size: 0.8rem;
  font-weight: 700;
}

.group-card__admin {
  text-align: right;
}

.group-card__admin-label {
  color: #7F8CA2;
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.group-card__admin-name {
  color: #E5EBF5;
  font-size: 0.9rem;
  font-weight: 700;
}

.group-card__footer {
  display: flex;
  justify-content: flex-start;
}

.group-card__role {
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 0.72rem;
  font-weight: 700;
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: #AEBAD0;
}

.group-card__role--admin {
  border-color: rgba(29, 158, 117, 0.4);
  background: rgba(29, 158, 117, 0.18);
  color: #1D9E75;
}

.group-card__role--member {
  background: rgba(255, 255, 255, 0.05);
}

.group-card__action {
  margin-top: auto;
  width: 100%;
  padding: 10px 14px;
  border-radius: 12px;
  border: 1px solid rgba(29, 158, 117, 0.6);
  background: transparent;
  color: #B7F5DE;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.group-card__action:hover {
  border-color: rgba(29, 158, 117, 0.9);
  color: #E8FFF7;
}

.group-card__action--active {
  background: #1D9E75;
  color: #07130f;
  border-color: rgba(29, 158, 117, 0.9);
  box-shadow: 0 12px 24px rgba(29, 158, 117, 0.3);
}

.group-card__action--discover {
  border-style: dashed;
}

.group-card__action--leave {
  border-color: rgba(255, 88, 104, 0.6);
  color: #FFB3BD;
  background: rgba(255, 88, 104, 0.1);
}

.group-card__action--leave:hover {
  border-color: rgba(255, 88, 104, 0.9);
  color: #FFD6DB;
}

.group-empty__cta {
  padding: 10px 24px;
  border-radius: 12px;
  border: 1px solid rgba(29, 158, 117, 0.5);
  background: rgba(29, 158, 117, 0.16);
  color: #CFFFEF;
  font-weight: 800;
  cursor: pointer;
}

@media (max-width: 1024px) {
  .groups-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .groups-hero {
    flex-direction: column;
    align-items: flex-start;
  }

  .groups-hero__cta {
    width: 100%;
  }

  .groups-grid {
    grid-template-columns: 1fr;
  }

  .groups-search {
    flex-wrap: wrap;
  }

  .groups-search__count {
    margin-left: auto;
  }
}

.expenses-editor__empty-members {
  padding: 18px;
  border: 1px dashed rgba(82, 97, 136, 0.24);
  border-radius: 16px;
  color: #97A7C0;
  font-size: 0.9rem;
  text-align: center;
}

[data-theme="light"] .expenses-editor__split-copy,
[data-theme="light"] .expenses-editor__summary-bar,
[data-theme="light"] .expenses-editor__empty-members {
  color: #5C6F88;
}

[data-theme="light"] .expenses-editor__mode-toggle,
[data-theme="light"] .expenses-editor__selected-card,
[data-theme="light"] .expenses-editor__utility-button,
[data-theme="light"] .expenses-editor__utility-link,
[data-theme="light"] .expenses-editor__percentage-input,
[data-theme="light"] .expenses-editor__select-trigger,
[data-theme="light"] .expenses-editor__select-menu {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .expenses-editor__mode-button {
  color: #5B6D86;
}

[data-theme="light"] .expenses-editor__mode-button--active {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
  color: #18304D;
}

[data-theme="light"] .expenses-editor__selected-share {
  color: #0B6B58;
}

[data-theme="light"] .expenses-editor__selected-badge {
  background: rgba(15, 159, 132, 0.12);
  color: #0B6B58;
}

[data-theme="light"] .expenses-editor__percentage-input {
  color: #18304D;
}

[data-theme="light"] .expenses-editor__percentage-symbol {
  color: #62748D;
}

[data-theme="light"] .expenses-editor__select-icon {
  background: linear-gradient(180deg, #F5F8FD, #EAF1FA);
  color: #0B6B58;
}

[data-theme="light"] .expenses-editor__select-option {
  color: #18304D;
}

[data-theme="light"] .expenses-editor__select-option:hover,
[data-theme="light"] .expenses-editor__select-option--active {
  background: rgba(47, 118, 222, 0.12);
}

[data-theme="light"] .expenses-editor__select-option-avatar {
  background: linear-gradient(180deg, #F5F8FD, #EAF1FA);
  color: #0B6B58;
}

[data-theme="light"] .expenses-editor__remove-member {
  border-color: rgba(220, 74, 88, 0.22);
  background: rgba(220, 74, 88, 0.08);
  color: #C53A4C;
}

[data-theme="light"] .expenses-editor__empty-members {
  border-color: #D3DDEA;
}

[data-theme="light"] .expenses-editor__warning {
  border-color: rgba(220, 74, 88, 0.2);
  background: rgba(220, 74, 88, 0.08);
  color: #C53A4C;
}

@media (max-width: 900px) {
  .expenses-editor__member-picker,
  .expenses-editor__selected-card {
    grid-template-columns: 1fr;
  }

  .expenses-editor__mode-row,
  .expenses-editor__summary-bar {
    align-items: flex-start;
  }
}

@media (max-width: 640px) {
  .expenses-editor__mode-toggle {
    width: 100%;
    justify-content: stretch;
  }

  .expenses-editor__mode-button {
    flex: 1 1 0;
  }

  .expenses-editor__utility-button,
  .expenses-editor__utility-link,
  .expenses-editor__percentage-input {
    width: 100%;
  }

  .expenses-editor__percentage-field {
    width: 100%;
  }
}

.expenses-page {
  display: grid;
  gap: 22px;
}

.expenses-empty-state {
  position: relative;
  overflow: hidden;
  display: grid;
  justify-items: center;
  gap: 12px;
  padding: 56px 24px;
  border: 1px solid rgba(76, 99, 143, 0.24);
  border-radius: 30px;
  background:
    radial-gradient(circle at top center, rgba(54, 214, 173, 0.16), transparent 34%),
    linear-gradient(145deg, rgba(13, 19, 35, 0.96), rgba(15, 21, 38, 0.92));
  box-shadow:
    0 26px 60px rgba(2, 8, 20, 0.44),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
  text-align: center;
}

.expenses-empty-state__orb {
  position: absolute;
  top: -72px;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(54, 214, 173, 0.28), transparent 68%);
  filter: blur(8px);
}

.expenses-empty-state__eyebrow,
.expenses-empty__eyebrow,
.expenses-split__eyebrow {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #84E7CA;
  font-weight: 700;
}

.expenses-empty-state__title,
.expenses-empty__title,
.expenses-feed__title,
.expenses-split__title {
  margin: 0;
  color: #F2F6FF;
  font-family: "Syne", sans-serif;
  font-weight: 800;
}

.expenses-empty-state__title {
  font-size: 2rem;
}

.expenses-empty-state__copy,
.expenses-empty__copy,
.expenses-feed__copy {
  margin: 0;
  max-width: 520px;
  color: #91A2BE;
  font-size: 0.98rem;
  line-height: 1.6;
}

.expenses-empty-state__action,
.expenses-empty__action,
.expenses-hero__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 50px;
  padding: 0 22px;
  border: 1px solid rgba(73, 234, 187, 0.28);
  border-radius: 16px;
  background: linear-gradient(135deg, #22C59A 0%, #3A7BFF 100%);
  color: #07131B;
  font-weight: 800;
  text-decoration: none;
  box-shadow: 0 18px 34px rgba(38, 118, 255, 0.18);
  transition: transform 0.24s ease, box-shadow 0.24s ease, filter 0.24s ease;
}

.expenses-empty-state__action:hover,
.expenses-empty__action:hover,
.expenses-hero__action:hover {
  transform: translateY(-2px);
  box-shadow: 0 22px 38px rgba(38, 118, 255, 0.24);
  filter: saturate(1.06);
}

.expenses-hero {
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
  gap: 24px;
  padding: 28px;
  border: 1px solid rgba(78, 95, 145, 0.22);
  border-radius: 32px;
  background:
    linear-gradient(135deg, rgba(10, 16, 30, 0.97) 0%, rgba(14, 21, 39, 0.95) 52%, rgba(20, 31, 58, 0.95) 100%);
  box-shadow:
    0 24px 58px rgba(2, 10, 26, 0.42),
    inset 0 1px 0 rgba(255, 255, 255, 0.06);
}

.expenses-hero__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(16px);
  opacity: 0.8;
}

.expenses-hero__glow--left {
  top: -24px;
  left: -24px;
  width: 190px;
  height: 190px;
  background: rgba(32, 197, 158, 0.18);
}

.expenses-hero__glow--right {
  right: -34px;
  bottom: -46px;
  width: 220px;
  height: 220px;
  background: rgba(67, 120, 255, 0.18);
}

.expenses-hero__copy,
.expenses-hero__aside {
  position: relative;
  z-index: 1;
}

.expenses-hero__copy {
  display: grid;
  align-content: center;
  gap: 16px;
}

.expenses-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  padding: 0.6rem 0.95rem;
  border: 1px solid rgba(84, 223, 189, 0.22);
  border-radius: 999px;
  background: rgba(10, 18, 36, 0.7);
  color: #7DE8C8;
  font-size: 0.74rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.expenses-hero__title {
  margin: 0;
  color: #F7FAFF;
  font-family: "Syne", sans-serif;
  font-size: clamp(2.6rem, 5vw, 4.5rem);
  font-weight: 800;
  line-height: 0.94;
}

.expenses-hero__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.expenses-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40px;
  padding: 0 14px;
  border: 1px solid rgba(84, 100, 138, 0.24);
  border-radius: 999px;
  background: rgba(11, 18, 33, 0.8);
  color: #AFC0DD;
  font-size: 0.9rem;
  font-weight: 700;
}

.expenses-chip--accent {
  border-color: rgba(35, 201, 159, 0.3);
  color: #73EDC8;
  background: rgba(13, 52, 48, 0.55);
}

.expenses-chip--soft {
  border-color: rgba(83, 124, 255, 0.26);
  color: #9EB8FF;
  background: rgba(24, 37, 82, 0.56);
}

.expenses-hero__aside {
  display: grid;
  gap: 16px;
  align-content: space-between;
}

.expenses-hero__panel {
  display: grid;
  gap: 12px;
  padding: 18px;
  border: 1px solid rgba(79, 96, 136, 0.18);
  border-radius: 24px;
  background: rgba(12, 18, 32, 0.74);
  backdrop-filter: blur(18px);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

.expenses-hero__panel-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.02);
}

.expenses-hero__panel-label,
.expenses-stat__label,
.expenses-toolbar__meta-label,
.expenses-card__amount-label,
.expenses-card__members-label,
.expenses-split__summary-label,
.expenses-field__label {
  color: #8EA0BC;
  font-size: 0.8rem;
  font-weight: 700;
}

.expenses-hero__panel-value,
.expenses-toolbar__meta-value {
  color: #F3F7FF;
  font-size: 1.02rem;
  font-weight: 800;
}

.expenses-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.expenses-stat {
  display: grid;
  gap: 10px;
  padding: 20px 22px;
  border: 1px solid rgba(75, 93, 135, 0.2);
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(11, 17, 30, 0.94), rgba(14, 20, 35, 0.94)),
    radial-gradient(circle at top right, rgba(70, 127, 255, 0.08), transparent 30%);
  box-shadow:
    0 18px 36px rgba(4, 10, 23, 0.32),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
}

.expenses-stat--feature {
  border-color: rgba(40, 204, 162, 0.26);
  background:
    radial-gradient(circle at top left, rgba(40, 204, 162, 0.14), transparent 32%),
    linear-gradient(180deg, rgba(11, 17, 30, 0.96), rgba(14, 20, 35, 0.94));
}

.expenses-stat__value {
  color: #F4F8FF;
  font-size: clamp(1.55rem, 3vw, 2.2rem);
  font-weight: 800;
  line-height: 1;
}

.expenses-stat__meta {
  color: #7F91AE;
  font-size: 0.94rem;
}

.expenses-toolbar,
.expenses-feed,
.expenses-empty {
  padding: 20px 22px;
  border: 1px solid rgba(76, 93, 137, 0.2);
  border-radius: 28px;
  background:
    linear-gradient(180deg, rgba(11, 17, 30, 0.94), rgba(13, 19, 35, 0.96)),
    radial-gradient(circle at top left, rgba(42, 202, 160, 0.06), transparent 28%);
  box-shadow:
    0 18px 40px rgba(3, 8, 20, 0.34),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
}

.expenses-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.7fr) auto;
  gap: 14px;
  align-items: end;
}

.expenses-filter {
  display: grid;
  gap: 10px;
}

.expenses-filter__label {
  color: #8EA0BC;
  font-size: 0.76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.expenses-filter__input,
.expenses-filter__select,
.expenses-field__input {
  width: 100%;
  min-height: 54px;
  border: 1px solid rgba(81, 97, 136, 0.24);
  border-radius: 18px;
  background: rgba(14, 20, 34, 0.88);
  color: #F3F7FF;
  padding: 0 16px;
  font-size: 1rem;
  transition: border-color 0.24s ease, box-shadow 0.24s ease, transform 0.24s ease, background 0.24s ease;
}

.expenses-filter__input:hover,
.expenses-filter__select:hover,
.expenses-field__input:hover {
  border-color: rgba(102, 121, 168, 0.34);
}

.expenses-filter__input:focus,
.expenses-filter__select:focus,
.expenses-field:focus-within .expenses-field__input,
.expenses-field__input:focus {
  outline: none;
  border-color: rgba(74, 214, 179, 0.44);
  box-shadow:
    0 0 0 3px rgba(58, 196, 166, 0.12),
    0 16px 28px rgba(5, 13, 30, 0.24);
  background: rgba(15, 22, 37, 0.96);
}

.expenses-filter--compact {
  max-width: 260px;
}

.expenses-toolbar__meta {
  display: grid;
  gap: 6px;
  min-width: 120px;
  padding: 12px 14px;
  border: 1px solid rgba(80, 96, 133, 0.18);
  border-radius: 18px;
  background: rgba(13, 19, 34, 0.68);
}

.expenses-feed {
  display: grid;
  gap: 18px;
}

.expenses-feed__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.expenses-list {
  display: grid;
  gap: 14px;
}

.expenses-card {
  position: relative;
  overflow: hidden;
  display: grid;
  gap: 18px;
  padding: 20px;
  border: 1px solid color-mix(in srgb, var(--expense-accent) 22%, rgba(90, 103, 138, 0.22));
  border-radius: 24px;
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--expense-accent) 10%, transparent), transparent 28%),
    linear-gradient(180deg, rgba(16, 22, 37, 0.96), rgba(12, 18, 32, 0.95));
  box-shadow:
    0 18px 34px rgba(2, 8, 20, 0.28),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
}

.expenses-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 24px 42px color-mix(in srgb, var(--expense-accent) 12%, rgba(2, 8, 20, 0.34));
}

.expenses-card__top,
.expenses-card__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
}

.expenses-card__identity,
.expenses-card__heading,
.expenses-card__members,
.expenses-card__meta,
.expenses-card__actions,
.expenses-modal__title-group,
.expenses-form__actions {
  display: flex;
  align-items: center;
}

.expenses-card__identity {
  gap: 14px;
  min-width: 0;
}

.expenses-card__dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--expense-accent);
  box-shadow: 0 0 0 8px color-mix(in srgb, var(--expense-accent) 12%, transparent);
}

.expenses-card__copy {
  display: grid;
  gap: 8px;
  min-width: 0;
}

.expenses-card__heading {
  gap: 12px;
  flex-wrap: wrap;
}

.expenses-card__title {
  margin: 0;
  color: #F4F8FF;
  font-size: 1.15rem;
  font-weight: 800;
}

.expenses-card__category,
.expenses-card__meta-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34px;
  padding: 0 12px;
  border: 1px solid color-mix(in srgb, var(--expense-accent) 30%, rgba(88, 104, 141, 0.22));
  border-radius: 999px;
  background: color-mix(in srgb, var(--expense-accent) 14%, rgba(11, 17, 30, 0.86));
  color: color-mix(in srgb, var(--expense-accent) 72%, #EFF4FF);
  font-size: 0.82rem;
  font-weight: 700;
}

.expenses-card__description {
  margin: 0;
  color: #93A4C0;
  font-size: 0.96rem;
  line-height: 1.55;
}

.expenses-card__amounts {
  display: grid;
  gap: 6px;
  min-width: 180px;
  justify-items: end;
}

.expenses-card__amount-value {
  color: #F7FAFF;
  font-size: clamp(1.45rem, 3vw, 2rem);
  font-weight: 800;
  line-height: 1;
}

.expenses-card__amount-meta {
  color: #87E8CA;
  font-size: 0.92rem;
  font-weight: 700;
}

.expenses-card__bottom {
  flex-wrap: wrap;
}

.expenses-card__members {
  gap: 12px;
}

.expenses-card__avatars {
  display: flex;
  align-items: center;
}

.expenses-card__avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  margin-left: -8px;
  border: 2px solid rgba(12, 18, 31, 0.98);
  border-radius: 50%;
  background: rgba(22, 34, 58, 0.92);
  color: #DCE7FA;
  font-size: 0.72rem;
  font-weight: 800;
}

.expenses-card__avatar:first-child {
  margin-left: 0;
}

.expenses-card__avatar--count {
  background: rgba(14, 21, 36, 0.98);
  color: #9DB0CE;
}

.expenses-card__meta {
  gap: 10px;
  flex-wrap: wrap;
}

.expenses-card__actions {
  gap: 10px;
  margin-left: auto;
}

.expenses-card__action,
.expenses-form__action {
  min-height: 44px;
  padding: 0 16px;
  border-radius: 14px;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease, background 0.22s ease;
}

.expenses-card__action {
  border: 1px solid rgba(82, 98, 136, 0.24);
  background: rgba(17, 24, 40, 0.84);
  color: #D9E5F8;
}

.expenses-card__action:hover,
.expenses-form__action:hover {
  transform: translateY(-1px);
}

.expenses-card__action--secondary {
  border-color: rgba(87, 133, 255, 0.28);
  color: #9CB9FF;
}

.expenses-card__action--danger {
  border-color: rgba(234, 91, 110, 0.26);
  color: #FF8E9F;
}

.expenses-feed__footer {
  padding-top: 6px;
}

.expenses-empty {
  display: grid;
  gap: 14px;
  justify-items: start;
}

.expenses-modal {
  max-width: 760px;
  border-color: rgba(82, 100, 146, 0.24);
  background:
    radial-gradient(circle at top left, rgba(42, 197, 160, 0.12), transparent 22%),
    radial-gradient(circle at bottom right, rgba(63, 121, 255, 0.1), transparent 24%),
    linear-gradient(145deg, rgba(10, 16, 30, 0.98), rgba(13, 20, 37, 0.98));
}

.expenses-modal .app-modal__header {
  padding-bottom: 12px;
}

.expenses-modal .app-modal__title {
  width: 100%;
  padding-right: 16px;
}

.expenses-modal__title-group {
  gap: 14px;
}

.expenses-modal__logo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 46px;
  height: 46px;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(31, 188, 149, 0.34), rgba(17, 72, 83, 0.82));
  color: #BAF5E6;
  font-size: 0.86rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
}

.expenses-modal__logo--edit {
  background: linear-gradient(135deg, rgba(77, 120, 255, 0.34), rgba(23, 41, 96, 0.88));
  color: #D7E4FF;
}

.expenses-modal__title-copy {
  color: #F6FAFF;
  font-family: "Syne", sans-serif;
  font-size: 1.9rem;
  font-weight: 800;
  line-height: 1;
}

.expenses-form {
  display: grid;
  gap: 18px;
}

.expenses-form__surface {
  display: grid;
  gap: 18px;
  padding: 8px 0 0;
}

.expenses-form__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.expenses-form__grid--hero {
  align-items: stretch;
}

.expenses-field {
  position: relative;
  display: grid;
  gap: 10px;
  padding: 16px;
  border: 1px solid rgba(79, 95, 133, 0.2);
  border-radius: 22px;
  background:
    linear-gradient(180deg, rgba(15, 21, 36, 0.92), rgba(13, 18, 32, 0.94)),
    radial-gradient(circle at top left, rgba(55, 216, 173, 0.08), transparent 28%);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  transition: border-color 0.24s ease, transform 0.24s ease, box-shadow 0.24s ease;
}

.expenses-field:hover,
.expenses-field:focus-within {
  border-color: rgba(73, 214, 178, 0.28);
  transform: translateY(-1px);
  box-shadow: 0 16px 28px rgba(3, 10, 24, 0.22);
}

.expenses-field__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: 1px solid rgba(78, 95, 136, 0.24);
  border-radius: 12px;
  background: rgba(13, 20, 34, 0.84);
  color: #8DE8CC;
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
}

.expenses-field__required {
  color: #FF8C9D;
}

.expenses-field__input {
  min-height: 52px;
  padding: 0 16px;
}

.expenses-field__input--select {
  cursor: pointer;
}

.expenses-field__input--textarea {
  min-height: 120px;
  padding: 14px 16px;
  resize: vertical;
}

.expenses-field__hint,
.expenses-split__note {
  color: #7E91AE;
  font-size: 0.86rem;
}

.expenses-split {
  display: grid;
  gap: 18px;
  padding: 18px;
  border: 1px solid rgba(77, 95, 135, 0.2);
  border-radius: 26px;
  background:
    radial-gradient(circle at top left, rgba(60, 207, 169, 0.08), transparent 30%),
    linear-gradient(180deg, rgba(13, 19, 35, 0.94), rgba(11, 17, 30, 0.96));
}

.expenses-split__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.expenses-split__title {
  font-size: 1.22rem;
}

.expenses-split__summary {
  display: grid;
  gap: 6px;
  min-width: 150px;
  padding: 12px 14px;
  border: 1px solid rgba(39, 198, 158, 0.24);
  border-radius: 18px;
  background: rgba(12, 34, 33, 0.54);
}

.expenses-split__summary-value {
  color: #84F0D1;
  font-size: 1.2rem;
  font-weight: 800;
}

.expenses-split__members {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}

.expenses-member-chip {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  min-height: 62px;
  padding: 12px;
  border: 1px solid rgba(79, 95, 135, 0.22);
  border-radius: 18px;
  background: rgba(14, 20, 34, 0.84);
  color: #E3EBF8;
  cursor: pointer;
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
  text-align: left;
}

.expenses-member-chip:hover {
  transform: translateY(-1px);
  border-color: rgba(104, 121, 170, 0.3);
}

.expenses-member-chip--selected {
  border-color: rgba(47, 213, 174, 0.28);
  background:
    radial-gradient(circle at top left, rgba(47, 213, 174, 0.14), transparent 30%),
    rgba(13, 25, 31, 0.92);
  box-shadow: 0 16px 30px rgba(3, 11, 24, 0.22);
}

.expenses-member-chip__avatar {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 14px;
  background: rgba(22, 35, 56, 0.94);
  color: #A8C0E6;
  font-size: 0.8rem;
  font-weight: 800;
  flex-shrink: 0;
}

.expenses-member-chip--selected .expenses-member-chip__avatar {
  background: linear-gradient(135deg, rgba(32, 194, 154, 0.28), rgba(22, 48, 55, 0.94));
  color: #D5FBF0;
}

.expenses-member-chip__name {
  color: #EDF3FF;
  font-size: 0.96rem;
  font-weight: 700;
}

.expenses-form__actions {
  justify-content: flex-end;
  gap: 12px;
}

.expenses-form__action {
  border: 1px solid rgba(79, 95, 135, 0.24);
  background: rgba(14, 20, 34, 0.84);
  color: #E3EBFA;
}

.expenses-form__action--ghost {
  min-width: 132px;
}

.expenses-form__action--primary {
  min-width: 180px;
  border-color: rgba(65, 205, 169, 0.26);
  background: linear-gradient(135deg, #1FC39A 0%, #327EFF 100%);
  color: #07131B;
  box-shadow: 0 18px 34px rgba(35, 110, 255, 0.2);
}

.expenses-form__action--primary:disabled {
  opacity: 0.72;
  cursor: not-allowed;
}

[data-theme="light"] .expenses-empty-state {
  border-color: #D3DDEA;
  background:
    radial-gradient(circle at top center, rgba(18, 168, 138, 0.12), transparent 36%),
    linear-gradient(145deg, #FFFFFF, #F5F9FE 58%, #EEF5FF 100%);
  box-shadow:
    0 24px 48px rgba(19, 37, 71, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .expenses-empty-state__title,
[data-theme="light"] .expenses-empty__title,
[data-theme="light"] .expenses-feed__title,
[data-theme="light"] .expenses-split__title,
[data-theme="light"] .expenses-card__title,
[data-theme="light"] .expenses-modal__title-copy,
[data-theme="light"] .expenses-stat__value,
[data-theme="light"] .expenses-card__amount-value,
[data-theme="light"] .expenses-hero__panel-value,
[data-theme="light"] .expenses-toolbar__meta-value {
  color: #14263F;
}

[data-theme="light"] .expenses-empty-state__copy,
[data-theme="light"] .expenses-empty__copy,
[data-theme="light"] .expenses-feed__copy,
[data-theme="light"] .expenses-card__description,
[data-theme="light"] .expenses-stat__meta,
[data-theme="light"] .expenses-field__hint,
[data-theme="light"] .expenses-split__note {
  color: #53657D;
}

[data-theme="light"] .expenses-empty-state__action,
[data-theme="light"] .expenses-empty__action,
[data-theme="light"] .expenses-hero__action,
[data-theme="light"] .expenses-form__action--primary {
  box-shadow: 0 18px 34px rgba(47, 118, 222, 0.18);
}

[data-theme="light"] .expenses-hero {
  border-color: #D3DDEA;
  background:
    radial-gradient(circle at top left, rgba(18, 168, 138, 0.16), transparent 32%),
    radial-gradient(circle at bottom right, rgba(59, 132, 232, 0.14), transparent 30%),
    linear-gradient(135deg, #FFFFFF 0%, #F7FBFF 55%, #EEF5FF 100%);
  box-shadow:
    0 24px 52px rgba(19, 37, 71, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .expenses-hero__eyebrow,
[data-theme="light"] .expenses-chip,
[data-theme="light"] .expenses-hero__panel,
[data-theme="light"] .expenses-toolbar__meta,
[data-theme="light"] .expenses-card__avatar,
[data-theme="light"] .expenses-form__action,
[data-theme="light"] .expenses-field__badge {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
}

[data-theme="light"] .expenses-hero__title {
  color: #12233A;
}

[data-theme="light"] .expenses-chip {
  color: #5C6F88;
}

[data-theme="light"] .expenses-chip--accent {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.14), rgba(255, 255, 255, 0.98));
  color: #0B6B58;
}

[data-theme="light"] .expenses-chip--soft {
  border-color: rgba(47, 118, 222, 0.22);
  background: linear-gradient(180deg, rgba(47, 118, 222, 0.12), rgba(255, 255, 255, 0.98));
  color: #245FC1;
}

[data-theme="light"] .expenses-stat,
[data-theme="light"] .expenses-toolbar,
[data-theme="light"] .expenses-feed,
[data-theme="light"] .expenses-empty,
[data-theme="light"] .expenses-card,
[data-theme="light"] .expenses-field,
[data-theme="light"] .expenses-split,
[data-theme="light"] .expenses-modal {
  border-color: #D3DDEA;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 249, 253, 0.98)),
    radial-gradient(circle at top right, rgba(59, 132, 232, 0.08), transparent 28%);
  box-shadow:
    0 18px 40px rgba(19, 37, 71, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.84);
}

[data-theme="light"] .expenses-stat--feature {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.14), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-hero__panel-row {
  background: rgba(245, 248, 252, 0.9);
}

[data-theme="light"] .expenses-hero__panel-label,
[data-theme="light"] .expenses-stat__label,
[data-theme="light"] .expenses-toolbar__meta-label,
[data-theme="light"] .expenses-card__amount-label,
[data-theme="light"] .expenses-card__members-label,
[data-theme="light"] .expenses-split__summary-label,
[data-theme="light"] .expenses-field__label,
[data-theme="light"] .expenses-filter__label {
  color: #62748D;
}

[data-theme="light"] .expenses-filter__input,
[data-theme="light"] .expenses-filter__select,
[data-theme="light"] .expenses-field__input {
  border-color: #D3DDEA;
  background: #FFFFFF;
  color: #17304E;
}

[data-theme="light"] .expenses-filter__input:focus,
[data-theme="light"] .expenses-filter__select:focus,
[data-theme="light"] .expenses-field:focus-within .expenses-field__input,
[data-theme="light"] .expenses-field__input:focus {
  border-color: rgba(47, 118, 222, 0.3);
  box-shadow:
    0 0 0 3px rgba(47, 118, 222, 0.1),
    0 14px 24px rgba(34, 55, 92, 0.1);
  background: #FFFFFF;
}

[data-theme="light"] .expenses-card__meta-pill {
  color: #4F6281;
}

[data-theme="light"] .expenses-card__amount-meta,
[data-theme="light"] .expenses-split__summary-value,
[data-theme="light"] .expenses-empty-state__eyebrow,
[data-theme="light"] .expenses-empty__eyebrow,
[data-theme="light"] .expenses-split__eyebrow,
[data-theme="light"] .expenses-hero__eyebrow {
  color: #0B6B58;
}

[data-theme="light"] .expenses-member-chip {
  border-color: #D3DDEA;
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
}

[data-theme="light"] .expenses-member-chip__avatar {
  background: linear-gradient(180deg, #F5F8FD, #EAF1FA);
  color: #55739A;
}

[data-theme="light"] .expenses-member-chip__name {
  color: #18304D;
}

[data-theme="light"] .expenses-member-chip--selected {
  border-color: rgba(15, 159, 132, 0.24);
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.12), rgba(255, 255, 255, 0.98));
}

[data-theme="light"] .expenses-member-chip--selected .expenses-member-chip__avatar {
  background: linear-gradient(180deg, rgba(15, 159, 132, 0.18), #F5FFFC);
  color: #0B6B58;
}

[data-theme="light"] .expenses-card__action {
  background: linear-gradient(180deg, #FFFFFF, #F4F8FD);
  color: #18304D;
}

[data-theme="light"] .expenses-card__action--secondary {
  border-color: rgba(47, 118, 222, 0.24);
  color: #245FC1;
}

[data-theme="light"] .expenses-card__action--danger {
  border-color: rgba(220, 74, 88, 0.24);
  color: #C53A4C;
}

@media (max-width: 960px) {
  .expenses-hero,
  .expenses-toolbar,
  .expenses-stats,
  .expenses-form__grid {
    grid-template-columns: 1fr;
  }

  .expenses-hero__aside {
    grid-template-columns: 1fr;
  }

  .expenses-card__top,
  .expenses-card__bottom,
  .expenses-split__header {
    flex-direction: column;
    align-items: flex-start;
  }

  .expenses-card__amounts {
    justify-items: start;
    min-width: 0;
  }

  .expenses-card__actions {
    margin-left: 0;
  }
}

@media (max-width: 640px) {
  .expenses-page {
    gap: 18px;
  }

  .expenses-hero,
  .expenses-toolbar,
  .expenses-feed,
  .expenses-empty,
  .expenses-empty-state,
  .expenses-stat,
  .expenses-split,
  .expenses-field {
    padding: 18px;
    border-radius: 24px;
  }

  .expenses-hero__title {
    font-size: 2.8rem;
  }

  .expenses-hero__action,
  .expenses-empty__action,
  .expenses-empty-state__action,
  .expenses-form__action {
    width: 100%;
  }

  .expenses-card {
    padding: 18px;
  }

  .expenses-card__members,
  .expenses-card__meta,
  .expenses-card__actions,
  .expenses-form__actions {
    width: 100%;
    flex-wrap: wrap;
  }

  .expenses-card__action {
    flex: 1 1 0;
  }

  .expenses-modal__title-copy {
    font-size: 1.5rem;
  }
}

.expenses-controls {
  position: relative;
  z-index: 12;
}

.expenses-ledger {
  position: relative;
  z-index: 1;
}

@media (max-width: 900px) {
  .expenses-header {
    align-items: stretch;
  }

  .expenses-header__main {
    width: 100%;
  }

  .expenses-header__stats {
    grid-template-columns: repeat(3, minmax(88px, 1fr));
  }
}

@media (max-width: 640px) {
  .expenses-controls {
    grid-template-columns: 1fr;
    gap: 10px;
    padding: 14px;
    align-items: stretch;
  }

  .expenses-controls__search,
  .expenses-filter-select__trigger,
  .expenses-controls__count {
    min-height: 46px;
    border-radius: 14px;
  }

  .expenses-controls__count {
    justify-content: flex-start;
    padding: 0 14px;
    font-size: 0.88rem;
  }

  .expenses-filter-select__menu {
    position: static;
    margin-top: 8px;
    max-height: 220px;
    overflow-y: auto;
    border-radius: 16px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .expenses-filter-select__option {
    min-height: 40px;
    border-radius: 10px;
  }

  .expenses-header__stats {
    grid-template-columns: repeat(3, minmax(88px, 1fr));
    gap: 10px;
  }

  .expenses-mini-stat {
    min-height: auto;
    padding: 14px;
  }

  .expenses-mini-stat__value {
    font-size: 1rem;
  }

  .expenses-header__action {
    width: 100%;
  }

  .expenses-row {
    grid-template-columns: 1fr;
    gap: 14px;
    padding: 16px;
  }

  .expenses-row__left {
    align-items: flex-start;
  }

  .expenses-row__content {
    gap: 8px;
  }

  .expenses-row__meta {
    gap: 8px;
  }

  .expenses-row__meta span:not(:last-child)::after {
    margin-left: 8px;
  }

  .expenses-row__right {
    display: grid;
    width: 100%;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      "amount people"
      "actions actions";
    align-items: center;
    gap: 12px;
  }

  .expenses-row__people {
    grid-area: people;
    width: auto;
    max-width: 100%;
    justify-self: end;
  }

  .expenses-row__amount {
    grid-area: amount;
    width: auto;
    font-size: 1.05rem;
  }

  .expenses-row__actions {
    grid-area: actions;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .expenses-row__action {
    width: 100%;
  }
}

/* Restored page layouts */
.members-grid--single {
  grid-template-columns: minmax(280px, 560px);
  justify-content: start;
}

.members-grid--double {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.members-grid--scroll {
  grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
}

.member-card {
  width: 100%;
  align-self: start;
}

.member-card__balance-value {
  word-break: break-word;
}

.member-card__actions {
  align-items: stretch;
}

.member-dash {
  display: grid;
  gap: 20px;
}

.member-dash-hero {
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.7fr);
  gap: 18px;
  padding: 24px;
  border-radius: 30px;
  border: 1px solid color-mix(in srgb, var(--accent) 16%, var(--border));
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 15%, transparent), transparent 34%),
    radial-gradient(circle at bottom right, color-mix(in srgb, var(--blue) 13%, transparent), transparent 30%),
    linear-gradient(145deg, color-mix(in srgb, var(--surface-alt) 97%, transparent), color-mix(in srgb, var(--surface) 99%, transparent));
  box-shadow: var(--shadow-md);
}

.member-dash-hero::after {
  content: "";
  position: absolute;
  inset: auto -80px -120px auto;
  width: 220px;
  height: 220px;
  border-radius: 50%;
  filter: blur(24px);
  opacity: 0.7;
  pointer-events: none;
}

.member-dash-hero--positive::after {
  background: color-mix(in srgb, var(--accent) 18%, transparent);
}

.member-dash-hero--negative::after {
  background: color-mix(in srgb, var(--red) 18%, transparent);
}

.member-dash-hero--settled::after {
  background: color-mix(in srgb, var(--blue) 16%, transparent);
}

.member-dash-hero__left,
.member-dash-hero__balance-card {
  position: relative;
  z-index: 1;
}

.member-dash-hero__left {
  display: grid;
  align-content: center;
  gap: 14px;
}

.member-dash-hero__eyebrow {
  width: fit-content;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.member-dash-hero__title {
  margin: 0;
  display: grid;
  gap: 2px;
  color: var(--text);
  font-size: clamp(1.8rem, 3.3vw, 2.9rem);
  line-height: 1.02;
  letter-spacing: -1.1px;
}

.member-dash-hero__title-text {
  display: block;
}

.member-dash-hero__name {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  min-height: 1.1em;
  color: var(--accent);
  text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 20%, transparent);
}

.member-dash-hero__caret {
  display: inline-block;
  width: 2px;
  height: 0.9em;
  margin-left: 4px;
  border-radius: 999px;
  background: var(--accent);
  box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 35%, transparent);
  animation: memberCaretBlink 0.85s steps(1) infinite;
}

@keyframes memberCaretBlink {
  0%,
  49% {
    opacity: 1;
  }

  50%,
  100% {
    opacity: 0;
  }
}

.member-dash-hero__chips,
.member-dash-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.member-dash-chip {
  display: inline-flex;
  align-items: center;
  min-height: 36px;
  padding: 0 13px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.member-dash-chip--accent {
  border-color: var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
}

.member-dash-chip--muted {
  border-color: color-mix(in srgb, var(--blue) 24%, var(--border));
  color: var(--primary);
}

.member-dash-hero__balance-card {
  display: grid;
  align-content: center;
  gap: 12px;
  padding: 20px;
  border-radius: 24px;
  border: 1px solid color-mix(in srgb, var(--accent) 15%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 10%, transparent), transparent 34%);
  box-shadow: var(--shadow);
}

.member-dash-hero__balance-label {
  color: var(--text-muted);
  font-size: 0.74rem;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.member-dash-hero__balance-value {
  color: var(--text);
  font-size: clamp(1.65rem, 2.9vw, 2.45rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.9px;
}

.member-dash-hero__balance-value--negative {
  color: var(--red);
}

.member-dash-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 0.82rem;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
}

.member-dash-btn:hover {
  transform: translateY(-1px);
}

.member-dash-btn--primary {
  background: linear-gradient(135deg, #2ecc9a 0%, #46a5ff 100%);
  color: #07151f;
  box-shadow: 0 14px 28px color-mix(in srgb, var(--accent) 22%, transparent);
}

.member-dash-btn--ghost {
  border-color: color-mix(in srgb, var(--blue) 18%, var(--border));
  background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt));
  color: var(--text);
}

.member-dash-kpis {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

.member-dash-kpi {
  display: grid;
  gap: 8px;
  min-height: 116px;
  padding: 18px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 10%, transparent), transparent 34%);
  box-shadow: var(--shadow);
}

.member-dash-kpi--green {
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
}

.member-dash-kpi--blue {
  border-color: color-mix(in srgb, var(--blue) 18%, var(--border));
}

.member-dash-kpi--violet {
  border-color: color-mix(in srgb, #b777ff 20%, var(--border));
}

.member-dash-kpi__label {
  color: var(--text-muted);
  font-size: 0.74rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.member-dash-kpi__value {
  color: var(--text);
  font-size: clamp(1.2rem, 2.1vw, 1.75rem);
  font-weight: 900;
  letter-spacing: -0.6px;
}

.member-dash-kpi__hint {
  color: var(--text-dim);
  font-size: 0.82rem;
  line-height: 1.55;
}

.member-dash-content {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  gap: 18px;
}

.member-dash-panel {
  border-radius: 24px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 30%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  padding: 20px;
  box-shadow: var(--shadow);
}

.member-dash-panel--chart,
.member-dash-panel--history {
  min-height: 320px;
}

.member-dash-panel__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}

.member-dash-panel__title {
  color: var(--text);
  font-size: 1.24rem;
  font-weight: 900;
  letter-spacing: -0.5px;
}

.member-dash-panel__subtitle {
  margin-top: 4px;
  color: var(--text-muted);
  font-size: 0.84rem;
  line-height: 1.55;
}

.member-dash-link {
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--primary);
  border-radius: 999px;
  padding: 8px 13px;
  font-size: 0.76rem;
  font-weight: 800;
  cursor: pointer;
}

.member-dash-history-list {
  display: grid;
  gap: 10px;
}

.member-dash-history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 14px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
}

.member-dash-history-item--payment {
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.member-dash-history-item--expense {
  border-color: color-mix(in srgb, var(--red) 16%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 9%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.member-dash-history-item__left {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
}

.member-dash-history-item__dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface-alt) 96%, var(--surface));
  color: var(--text);
  font-size: 0.72rem;
  font-weight: 800;
  flex: 0 0 auto;
}

.member-dash-history-item__content {
  min-width: 0;
}

.member-dash-history-item__title {
  color: var(--text);
  font-size: 0.92rem;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.member-dash-history-item__meta {
  margin-top: 3px;
  color: var(--text-muted);
  font-size: 0.77rem;
  line-height: 1.45;
}

.member-dash-history-item__amount {
  white-space: nowrap;
  font-size: 0.92rem;
  font-weight: 900;
}

.member-dash-history-item__amount.is-positive {
  color: var(--accent);
}

.member-dash-history-item__amount.is-negative {
  color: var(--red);
}

.member-dash-empty {
  min-height: 180px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  border: 1px dashed color-mix(in srgb, var(--blue) 18%, var(--border));
  color: var(--text-muted);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
}

.admin-dash {
  display: grid;
  gap: 20px;
}

.admin-dash-hero {
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
  gap: 18px;
  padding: 24px;
  border-radius: 30px;
  border: 1px solid color-mix(in srgb, var(--blue) 16%, var(--border));
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--blue) 16%, transparent), transparent 32%),
    radial-gradient(circle at bottom right, color-mix(in srgb, var(--accent) 14%, transparent), transparent 28%),
    linear-gradient(140deg, color-mix(in srgb, var(--surface-elevated) 96%, transparent), color-mix(in srgb, var(--surface) 99%, transparent));
  box-shadow: var(--shadow-md);
}

.admin-dash-hero::before {
  content: "";
  position: absolute;
  inset: auto -80px -120px auto;
  width: 240px;
  height: 240px;
  border-radius: 50%;
  opacity: 0.65;
  filter: blur(26px);
  pointer-events: none;
}

.admin-dash-hero--positive::before {
  background: color-mix(in srgb, var(--accent) 18%, transparent);
}

.admin-dash-hero--negative::before {
  background: color-mix(in srgb, var(--red) 18%, transparent);
}

.admin-dash-hero--neutral::before {
  background: color-mix(in srgb, var(--blue) 18%, transparent);
}

.admin-dash-hero__main,
.admin-dash-hero__aside {
  position: relative;
  z-index: 1;
}

.admin-dash-hero__main {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.admin-dash-hero__eyebrow {
  align-self: flex-start;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid color-mix(in srgb, var(--blue) 24%, var(--border));
  background: color-mix(in srgb, var(--blue) 10%, var(--surface));
  color: var(--primary);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.admin-dash-hero__title {
  margin: 0;
  display: grid;
  gap: 2px;
  font-size: clamp(1.8rem, 3.2vw, 2.9rem);
  line-height: 1.02;
  letter-spacing: -1.1px;
  color: var(--text);
}

.admin-dash-hero__title-text {
  display: block;
}

.admin-dash-hero__name {
  display: inline-flex;
  align-items: center;
  min-height: 1.1em;
  width: fit-content;
  color: var(--accent);
  text-shadow: 0 0 18px color-mix(in srgb, var(--accent) 20%, transparent);
}

.admin-dash-hero__caret {
  display: inline-block;
  width: 2px;
  height: 0.9em;
  margin-left: 4px;
  border-radius: 999px;
  background: var(--accent);
  box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 35%, transparent);
  animation: adminCaretBlink 0.85s steps(1) infinite;
}

@keyframes adminCaretBlink {
  0%,
  49% {
    opacity: 1;
  }

  50%,
  100% {
    opacity: 0;
  }
}

.admin-dash-hero__meta,
.admin-dash-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.admin-dash-pill {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.admin-dash-pill--accent {
  border-color: var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
}

.admin-dash-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 0.82rem;
  font-weight: 800;
  cursor: pointer;
  transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
}

.admin-dash-btn:hover {
  transform: translateY(-1px);
}

.admin-dash-btn--primary {
  background: linear-gradient(135deg, #3ba0ff 0%, #2ecc9a 100%);
  color: #06141f;
  box-shadow: 0 14px 28px color-mix(in srgb, var(--blue) 22%, transparent);
}

.admin-dash-btn--secondary {
  border-color: color-mix(in srgb, var(--blue) 20%, var(--border));
  background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt));
  color: var(--text);
}

.admin-dash-btn--block {
  width: 100%;
}

.admin-dash-hero__aside {
  display: grid;
  gap: 12px;
  align-content: stretch;
}

.admin-dash-spotlight {
  display: grid;
  gap: 8px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 96%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
}

.admin-dash-spotlight--blue {
  border-color: color-mix(in srgb, var(--blue) 22%, var(--border));
}

.admin-dash-spotlight--amber {
  border-color: color-mix(in srgb, var(--yellow) 22%, var(--border));
}

.admin-dash-spotlight__label {
  color: var(--text-muted);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.admin-dash-spotlight__value {
  color: var(--text);
  font-size: clamp(1.25rem, 2.2vw, 1.9rem);
  line-height: 1;
  letter-spacing: -0.6px;
}

.admin-dash-spotlight__note {
  color: var(--text-dim);
  font-size: 0.82rem;
  line-height: 1.55;
}

.admin-dash-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}

.admin-dash-summary-card {
  position: relative;
  display: grid;
  gap: 12px;
  min-height: 114px;
  padding: 18px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 10%, transparent), transparent 34%);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.admin-dash-summary-card::before {
  content: "";
  position: absolute;
  inset: 0 0 auto 0;
  height: 3px;
  background: var(--summary-accent, var(--primary));
  opacity: 0.95;
}

.admin-dash-summary-card--positive {
  --summary-accent: var(--accent);
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
}

.admin-dash-summary-card--negative {
  --summary-accent: var(--red);
  border-color: color-mix(in srgb, var(--red) 18%, var(--border));
}

.admin-dash-summary-card--neutral,
.admin-dash-summary-card--blue {
  --summary-accent: var(--primary);
  border-color: color-mix(in srgb, var(--blue) 18%, var(--border));
}

.admin-dash-summary-card--amber {
  --summary-accent: var(--yellow);
  border-color: color-mix(in srgb, var(--yellow) 18%, var(--border));
}

.admin-dash-summary-card--violet {
  --summary-accent: #b777ff;
  border-color: color-mix(in srgb, #b777ff 18%, var(--border));
}

.admin-dash-summary-card__label {
  color: var(--text-muted);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.admin-dash-summary-card__value {
  color: var(--text);
  font-size: 1.62rem;
  line-height: 1;
  letter-spacing: -0.8px;
  font-weight: 900;
}

.admin-dash-columns {
  display: grid;
  grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
  gap: 18px;
}

.admin-dash-stack {
  display: grid;
  gap: 18px;
  align-content: start;
}

.admin-dash-card {
  border-radius: 24px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 32%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  padding: 20px;
  box-shadow: var(--shadow);
}

.admin-dash-card--chart,
.admin-dash-card--tracker {
  min-height: 360px;
}

.admin-dash-card--tracker {
  display: flex;
  flex-direction: column;
}

.admin-dash-card__head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}

.admin-dash-card__title {
  color: var(--text);
  font-size: 1.28rem;
  font-weight: 900;
  letter-spacing: -0.6px;
}

.admin-dash-card__subtitle {
  margin-top: 5px;
  color: var(--text-muted);
  font-size: 0.84rem;
  line-height: 1.55;
}

.admin-dash-link {
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--primary);
  border-radius: 999px;
  padding: 8px 13px;
  font-size: 0.76rem;
  font-weight: 800;
  cursor: pointer;
}

.admin-dash-link--members {
  border-color: rgba(59, 160, 255, 0.3);
  background: linear-gradient(135deg, rgba(59, 160, 255, 0.16), rgba(46, 204, 154, 0.12));
  color: #8fdfff;
  box-shadow: 0 10px 24px rgba(32, 119, 215, 0.14);
}

.admin-dash-balance-list,
.admin-dash-category-list,
.admin-dash-activity-list {
  display: grid;
  gap: 10px;
}

.admin-dash-balance-row,
.admin-dash-activity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
}

.admin-dash-balance-row__left,
.admin-dash-activity-row__left {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
}

.admin-dash-balance-row__content,
.admin-dash-activity-row__content {
  min-width: 0;
}

.admin-dash-balance-row__name,
.admin-dash-activity-row__title {
  color: var(--text);
  font-size: 0.9rem;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.admin-dash-balance-row__role,
.admin-dash-activity-row__meta {
  margin-top: 3px;
  color: var(--text-muted);
  font-size: 0.76rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.admin-dash-balance-row__amount,
.admin-dash-activity-row__amount {
  white-space: nowrap;
  font-size: 0.9rem;
  font-weight: 800;
}

.admin-dash-balance-row__amount.is-positive,
.admin-dash-activity-row__amount.is-positive {
  color: var(--accent);
}

.admin-dash-balance-row__amount.is-negative,
.admin-dash-activity-row__amount.is-negative {
  color: var(--red);
}

.admin-dash-tracker-stats {
  display: grid;
  gap: 10px;
  flex: 1;
  margin-bottom: 14px;
  align-content: start;
}

.admin-dash-tracker-stat {
  display: grid;
  gap: 4px;
  padding: 14px;
  border-radius: 16px;
  border: 1px solid color-mix(in srgb, var(--blue) 16%, var(--border));
  background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt));
}

.admin-dash-tracker-stat__label {
  color: var(--text-muted);
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.7px;
}

.admin-dash-tracker-stat__value {
  color: var(--text);
  font-size: 1.2rem;
  letter-spacing: -0.5px;
}

.admin-dash-category-row {
  display: grid;
  gap: 8px;
}

.admin-dash-category-row__top {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  font-size: 0.82rem;
}

.admin-dash-category-row__name {
  color: var(--text);
  font-weight: 700;
  text-transform: capitalize;
}

.admin-dash-category-row__value {
  color: var(--text-muted);
  font-weight: 700;
  text-align: right;
}

.admin-dash-category-row__track {
  width: 100%;
  height: 8px;
  border-radius: 999px;
  background: var(--border);
  overflow: hidden;
}

.admin-dash-category-row__fill {
  height: 100%;
  border-radius: 999px;
}

.admin-dash-activity-row__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface-alt) 96%, var(--surface));
  color: var(--text);
  font-size: 0.72rem;
  font-weight: 800;
  flex: 0 0 auto;
}

.admin-dash-activity-row.is-payment {
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.admin-dash-activity-row.is-expense {
  border-color: color-mix(in srgb, var(--red) 18%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--red) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.admin-dash-activity-row.is-admin {
  border-color: color-mix(in srgb, var(--blue) 18%, var(--border));
  background: linear-gradient(180deg, color-mix(in srgb, var(--blue) 10%, var(--surface-alt)), color-mix(in srgb, var(--surface) 98%, transparent));
}

.admin-dash-empty {
  min-height: 180px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  border: 1px dashed color-mix(in srgb, var(--blue) 18%, var(--border));
  color: var(--text-muted);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
}

.requests-page,
.my-requests-page,
.history-page {
  display: grid;
  gap: 20px;
}

.requests-hero,
.my-requests-hero,
.history-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(220px, 0.65fr);
  gap: 16px;
  padding: 24px;
  border-radius: 28px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--accent) 12%, transparent), transparent 34%),
    radial-gradient(circle at bottom right, color-mix(in srgb, var(--blue) 10%, transparent), transparent 30%),
    linear-gradient(145deg, color-mix(in srgb, var(--surface-alt) 97%, transparent), color-mix(in srgb, var(--surface) 99%, transparent));
  box-shadow: var(--shadow);
}

.requests-hero__left,
.my-requests-hero__left,
.history-hero__left {
  display: grid;
  gap: 12px;
  align-content: center;
}

.requests-hero__eyebrow,
.my-requests-hero__eyebrow,
.history-hero__eyebrow {
  width: fit-content;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--accent-glow);
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.9px;
  text-transform: uppercase;
}

.requests-hero__title,
.my-requests-hero__title,
.history-hero__title {
  margin: 0;
  color: var(--text);
  font-size: clamp(1.7rem, 3vw, 2.45rem);
  font-weight: 900;
  letter-spacing: -1px;
}

.requests-hero__subtitle,
.my-requests-hero__subtitle,
.history-hero__subtitle {
  margin: 0;
  color: var(--text-dim);
  font-size: 0.92rem;
  line-height: 1.65;
  max-width: 680px;
}

.requests-hero__chips,
.my-requests-hero__chips,
.history-hero__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.requests-chip,
.my-requests-chip,
.history-chip {
  display: inline-flex;
  align-items: center;
  min-height: 36px;
  padding: 0 13px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.requests-chip--pending,
.my-requests-chip--pending {
  border-color: color-mix(in srgb, var(--yellow) 24%, var(--border));
  color: var(--yellow);
}

.requests-chip--accepted,
.my-requests-chip--accepted {
  border-color: var(--accent-glow);
  color: var(--accent);
}

.requests-chip--rejected,
.my-requests-chip--rejected {
  border-color: color-mix(in srgb, var(--red) 22%, var(--border));
  color: var(--red);
}

.history-chip--soft {
  border-color: color-mix(in srgb, var(--blue) 20%, var(--border));
  color: var(--primary);
}

.requests-hero__stat,
.my-requests-hero__stat,
.history-hero__right {
  display: grid;
  align-content: center;
  gap: 6px;
  padding: 18px 20px;
  border-radius: 22px;
  border: 1px solid color-mix(in srgb, var(--blue) 16%, var(--border));
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 95%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 34%);
}

.requests-hero__stat-label,
.requests-hero__stat-hint,
.my-requests-hero__stat-label,
.history-hero__stat-label,
.history-hero__stat-meta {
  color: var(--text-muted);
  font-size: 0.78rem;
}

.requests-hero__stat-value,
.my-requests-hero__stat-value,
.history-hero__stat-value {
  color: var(--text);
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  line-height: 1;
  font-weight: 900;
  letter-spacing: -1px;
}

.requests-switcher,
.my-requests-filter,
.history-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 12px;
  border-radius: 22px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface-alt) 95%, transparent);
  box-shadow: var(--shadow);
}

.requests-switcher__tab,
.my-requests-filter__tab,
.history-filter__tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--text-muted);
  font-size: 0.84rem;
  font-weight: 800;
  cursor: pointer;
}

.requests-switcher__tab--active,
.my-requests-filter__tab--active,
.history-filter__tab--active {
  border-color: var(--accent-glow);
  background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  color: var(--text);
}

.requests-switcher__count,
.my-requests-filter__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 24px;
  height: 24px;
  padding: 0 8px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt));
  font-size: 0.72rem;
}

.requests-list,
.my-requests-list,
.history-list {
  display: grid;
  gap: 14px;
}

.request-card,
.my-request-card,
.history-card {
  position: relative;
  overflow: hidden;
  border-radius: 26px;
  border: 1px solid var(--border);
  background:
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 32%),
    linear-gradient(180deg, color-mix(in srgb, var(--surface-alt) 98%, transparent), color-mix(in srgb, var(--surface) 98%, transparent));
  box-shadow: var(--shadow);
}

.request-card__rail,
.my-request-card__rail,
.history-card__rail {
  position: absolute;
  inset: 14px auto 14px 14px;
  width: 3px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--blue) 26%, transparent);
}

.request-card--pending .request-card__rail,
.my-request-card--pending .my-request-card__rail {
  background: color-mix(in srgb, var(--yellow) 42%, transparent);
}

.request-card--accepted .request-card__rail,
.my-request-card--accepted .my-request-card__rail,
.history-card--payment .history-card__rail,
.history-card--self .history-card__rail {
  background: color-mix(in srgb, var(--accent) 48%, transparent);
}

.request-card--rejected .request-card__rail,
.my-request-card--rejected .my-request-card__rail,
.history-card--expense .history-card__rail {
  background: color-mix(in srgb, var(--red) 48%, transparent);
}

.request-card__body,
.my-request-card__body {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16px;
  padding: 20px 20px 20px 28px;
}

.request-card__main {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  min-width: 0;
}

.request-card__copy,
.my-request-card__main {
  min-width: 0;
}

.request-card__name,
.my-request-card__group,
.history-card__title {
  color: var(--text);
  font-size: 1.08rem;
  font-weight: 900;
  letter-spacing: -0.3px;
}

.request-card__email,
.request-card__meta,
.my-request-card__meta,
.my-request-card__time,
.history-card__date,
.history-card__note-meta {
  color: var(--text-muted);
  font-size: 0.82rem;
  line-height: 1.55;
}

.request-card__message,
.request-card__reason,
.my-request-card__message,
.my-request-card__reason,
.history-card__note {
  margin-top: 8px;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text-dim);
  font-size: 0.84rem;
  line-height: 1.6;
}

.history-card__note--empty {
  min-height: 72px;
  background: color-mix(in srgb, var(--surface) 82%, transparent);
}

.request-card__actions,
.my-request-card__side {
  display: grid;
  align-content: center;
  gap: 10px;
}

.request-btn,
.my-request-card__go,
.history-empty-group__cta,
.requests-reject__cancel,
.requests-reject__confirm,
.request-status,
.my-request-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 14px;
  border: 1px solid transparent;
  font-size: 0.82rem;
  font-weight: 800;
  text-decoration: none;
}

.request-btn--accept,
.my-request-card__go,
.history-empty-group__cta,
.requests-reject__confirm {
  background: linear-gradient(135deg, #2ecc9a 0%, #46a5ff 100%);
  color: #07151f;
  box-shadow: 0 14px 28px color-mix(in srgb, var(--accent) 20%, transparent);
}

.request-btn--reject,
.requests-reject__cancel {
  border-color: color-mix(in srgb, var(--red) 22%, var(--border));
  background: color-mix(in srgb, var(--red) 10%, var(--surface));
  color: var(--red);
}

.request-status,
.my-request-status {
  border-color: var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text);
  text-transform: capitalize;
}

.request-status--accepted,
.my-request-status--accepted {
  border-color: var(--accent-glow);
  color: var(--accent);
}

.request-status--rejected,
.my-request-status--rejected {
  border-color: color-mix(in srgb, var(--red) 22%, var(--border));
  color: var(--red);
}

.request-status--pending,
.my-request-status--pending {
  border-color: color-mix(in srgb, var(--yellow) 22%, var(--border));
  color: var(--yellow);
}

.requests-empty,
.my-requests-empty,
.history-empty,
.history-empty-group {
  padding: 28px;
  border-radius: 26px;
  border: 1px dashed color-mix(in srgb, var(--blue) 18%, var(--border));
  background: color-mix(in srgb, var(--surface-alt) 96%, transparent);
}

.history-empty-group {
  display: grid;
  justify-items: center;
  gap: 12px;
  text-align: center;
}

.history-empty-group__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 92%, var(--surface-alt));
  color: var(--primary);
  font-size: 0.92rem;
  font-weight: 900;
}

.history-empty-group__title {
  margin: 0;
  color: var(--text);
  font-size: 1.25rem;
  font-weight: 900;
}

.history-empty-group__text {
  margin: 0;
  max-width: 420px;
  color: var(--text-dim);
  line-height: 1.6;
}

.requests-reject {
  display: grid;
  gap: 14px;
}

.requests-reject__copy {
  margin: 0;
  color: var(--text-dim);
  line-height: 1.6;
}

.requests-reject__field {
  display: grid;
  gap: 6px;
}

.requests-reject__field label {
  color: var(--text-muted);
  font-size: 0.8rem;
  font-weight: 700;
}

.requests-reject__actions {
  display: flex;
  gap: 10px;
}

.history-card__inner {
  padding: 20px 20px 20px 28px;
}

.history-card__top {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 16px;
  align-items: start;
}

.history-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 16px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 92%, var(--surface-alt));
  color: var(--text);
  font-size: 0.84rem;
  font-weight: 900;
}

.history-card__badge--payment,
.history-card__badge--self {
  color: var(--accent);
  border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
}

.history-card__badge--expense {
  color: var(--red);
  border-color: color-mix(in srgb, var(--red) 20%, var(--border));
}

.history-card__main {
  display: grid;
  gap: 12px;
  min-width: 0;
}

.history-card__header {
  display: grid;
  gap: 6px;
}

.history-card__eyebrow {
  width: fit-content;
  padding: 4px 10px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 88%, var(--surface-alt));
  color: var(--text-muted);
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: 0.8px;
  text-transform: uppercase;
}

.history-card__eyebrow--payment,
.history-card__amount--payment {
  color: var(--accent);
}

.history-card__eyebrow--expense,
.history-card__amount--expense {
  color: var(--red);
}

.history-card__eyebrow--self,
.history-card__amount--self {
  color: var(--primary);
}

.history-card__description {
  color: var(--text);
  font-size: 0.9rem;
  line-height: 1.6;
}

.history-card__side {
  display: grid;
  gap: 10px;
  justify-items: end;
  min-width: 160px;
}

.history-card__amount-box {
  display: grid;
  gap: 6px;
  min-width: 150px;
  padding: 16px 18px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--surface) 95%, transparent), color-mix(in srgb, var(--surface-elevated) 92%, transparent)),
    radial-gradient(circle at top right, color-mix(in srgb, var(--blue) 8%, transparent), transparent 34%);
}

.history-card__amount-box--payment,
.history-card__amount-box--self {
  border-color: color-mix(in srgb, var(--accent) 18%, var(--border));
}

.history-card__amount-box--expense {
  border-color: color-mix(in srgb, var(--red) 18%, var(--border));
}

.history-card__amount {
  font-size: 1.6rem;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.8px;
}

.history-card__side-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
}

.history-tag {
  display: inline-flex;
  align-items: center;
  min-height: 32px;
  padding: 0 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: color-mix(in srgb, var(--surface) 90%, var(--surface-alt));
  color: var(--text-muted);
  font-size: 0.74rem;
  font-weight: 800;
}

.history-tag--warn {
  border-color: color-mix(in srgb, var(--yellow) 22%, var(--border));
  color: var(--yellow);
}

.history-tag--muted {
  color: var(--text);
}

.history-tag--payment,
.history-tag--self {
  border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
  color: var(--accent);
}

.history-tag--expense {
  border-color: color-mix(in srgb, var(--red) 20%, var(--border));
  color: var(--red);
}

@media (max-width: 1120px) {
  .members-grid--double,
  .members-grid--scroll,
  .member-dash-hero,
  .member-dash-content,
  .admin-dash-hero,
  .admin-dash-columns,
  .requests-hero,
  .my-requests-hero,
  .history-hero {
    grid-template-columns: 1fr;
  }

  .admin-dash-summary {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 780px) {
  .member-dash-hero,
  .admin-dash-hero,
  .requests-hero,
  .my-requests-hero,
  .history-hero {
    padding: 18px;
    border-radius: 22px;
  }

  .member-dash-hero__title,
  .admin-dash-hero__title,
  .requests-hero__title,
  .my-requests-hero__title,
  .history-hero__title {
    font-size: 2rem;
  }

  .member-dash-kpis,
  .admin-dash-summary {
    grid-template-columns: 1fr;
  }

  .request-card__body,
  .my-request-card__body,
  .history-card__top {
    grid-template-columns: 1fr;
  }

  .admin-dash-card__head,
  .admin-dash-balance-row,
  .admin-dash-activity-row,
  .member-dash-history-item {
    flex-direction: column;
    align-items: flex-start;
  }

  .history-card__side {
    width: 100%;
    min-width: 0;
    justify-items: start;
  }

  .history-card__side-tags {
    justify-content: flex-start;
  }
}

@media (max-width: 640px) {
  .members-grid,
  .members-grid--single,
  .members-grid--double,
  .members-grid--scroll,
  .member-dash-kpis,
  .admin-dash-summary {
    grid-template-columns: 1fr;
  }

  .member-card {
    min-height: auto;
    padding: 18px;
    border-radius: 22px;
  }

  .member-card--with-actions {
    padding-bottom: 18px;
  }

  .member-card__top {
    grid-template-columns: 1fr;
    min-height: 0;
    gap: 12px;
  }

  .member-card__tag-rail {
    justify-content: flex-start;
    max-width: none;
  }

  .member-card__actions {
    position: static;
    margin-top: 14px;
    transform: none;
    opacity: 1;
    pointer-events: auto;
  }

  .member-dash-hero,
  .admin-dash-hero,
  .member-dash-panel,
  .admin-dash-card,
  .requests-hero,
  .my-requests-hero,
  .history-hero,
  .requests-switcher,
  .my-requests-filter,
  .history-filter,
  .request-card,
  .my-request-card,
  .history-card,
  .requests-empty,
  .my-requests-empty,
  .history-empty,
  .history-empty-group {
    border-radius: 20px;
  }

  .member-dash-hero__actions,
  .member-dash-btn,
  .admin-dash-hero__actions,
  .admin-dash-btn,
  .admin-dash-link,
  .request-btn,
  .my-request-card__go,
  .requests-reject__actions {
    width: 100%;
  }

  .requests-switcher,
  .my-requests-filter,
  .history-filter {
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .requests-switcher__tab,
  .my-requests-filter__tab,
  .history-filter__tab {
    flex: 0 0 auto;
  }

  .requests-reject__actions {
    display: grid;
    gap: 10px;
  }

  .history-card__amount-box {
    min-width: 0;
    width: 100%;
  }

  .history-card__amount {
    font-size: 1.3rem;
  }
}

@media (max-width: 560px) {
  .member-dash-hero__title,
  .admin-dash-hero__title,
  .requests-hero__title,
  .my-requests-hero__title,
  .history-hero__title {
    font-size: 1.55rem;
  }

  .member-dash-hero__balance-value,
  .admin-dash-summary-card__value,
  .history-card__amount,
  .requests-hero__stat-value,
  .my-requests-hero__stat-value,
  .history-hero__stat-value {
    font-size: 1.55rem;
  }

  .history-card__badge {
    width: 40px;
    height: 40px;
  }
}
