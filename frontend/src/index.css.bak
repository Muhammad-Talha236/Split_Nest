}

[data-theme="light"] .balance-member-card__back-admin {
  border-color: rgba(15, 159, 132, 0.18);
  background:
    linear-gradient(180deg, rgba(15, 159, 132, 0.10), rgba(255, 255, 255, 0.98)),
